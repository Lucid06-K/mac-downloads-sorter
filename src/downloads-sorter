    printf '\033[H\033[2J'
    printf '\n  %s\n' "${BLD}Downloads Sorter вЂ” activity log${R}"
    printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
    if [ ! -s "$LOG" ]; then
        printf '\n   %s(no activity yet)%s\n' "$DIM" "$R"
    else
        total=$(grep -cE ' (moved|archived|duplicate|renamed|unzipped): ' "$LOG" 2>/dev/null)
        tail -n 40 "$LOG" | tail -r | awk \
            -v today="$today" -v ydy="$ydy" -v tlbl="$today_lbl" -v ylbl="$ydy_lbl" \
            -v dim="$DIM" -v grn="$GRN" -v bld="$BLD" -v yel="$YEL" -v r="$R" '
        function header(d,   lbl) {
            if (d != lastd) {
                lbl = (d == today) ? tlbl : (d == ydy) ? ylbl : d
                printf "\n  %s%s%s\n", bld, lbl, r
                lastd = d
            }
        }
        {
            d = substr($0, 1, 10); t = substr($0, 12, 5)
            rest = substr($0, 21)                          # "verb: payload"
            ci = index(rest, ": ")
            verb = (ci ? substr(rest, 1, ci - 1) : "")
            payload = (ci ? substr(rest, ci + 2) : "")
            m = split(payload, p, " -> ")
            if (ci && m >= 2 && (verb=="moved" || verb=="archived" || verb=="duplicate" || verb=="renamed" || verb=="unzipped")) {
                dest = p[m]; sub(/\/$/, "", dest)
                name = p[1]; for (i = 2; i < m; i++) name = name " -> " p[i]
                if (length(name) > 38) name = substr(name, 1, 37) "вЂ¦"
                tag = (verb=="archived")  ? "  " dim "(archived)" r  \
                    : (verb=="duplicate") ? "  " dim "(dup)" r       \
                    : (verb=="renamed")   ? "  " dim "(renamed)" r   \
                    : (verb=="unzipped")  ? "  " dim "(unzipped)" r  : ""
                header(d)
                printf "   %s%s%s  %-38s %sв†’ %s%s%s\n", dim, t, r, name, grn, dest, r, tag
                moves++
            } else if (rest ~ /fail|error/) {
                header(d)                                  # genuine problems still stand out
                printf "   %sвљ  %s%s\n", yel, rest, r
            }
            # routine non-move lines (weekly digest, skipped, вЂ¦) are omitted from this compact view
        }
        END { if (!moves) printf "\n   %s(no moves in recent log)%s\n", dim, r }'
        printf '\n  %s\n' "${DIM}newest first В· showing last 40 entries В· $total moves in full log${R}"
        printf '  %s\n' "${DIM}full file: ~/Library/Logs/organize-downloads.log${R}"
    fi
    printf '\n  %s' "${DIM}press any key to return${R}"
    IFS= read -r -s -n 1 _ 2>/dev/null
}

# one keypress -> token (up/down/esc/ignore/empty-string for enter+space/literal char)
read_key() {
    local k rest d
    IFS= read -r -s -n 1 k || return 1
    if [ "$k" = $'\033' ]; then
        IFS= read -r -s -n 2 -t 1 rest 2>/dev/null
        case "$rest" in
            '[A') printf 'up' ;;
            '[B') printf 'down' ;;
            '')   printf 'esc' ;;      # a genuinely lone ESC key
            *)    # any other sequence (в†’/в†ђ, Home, End, Delete=[3~, PgUp/PgDn, F-keys):
                  # drain to its final byte and treat as a no-op вЂ” a stray arrow must
                  # NOT be read as Esc (which quits the menu) or leak bytes to the shell.
                  case "$rest" in *[A-Za-z~]) : ;; *)
                      while IFS= read -r -s -n 1 -t 1 d 2>/dev/null; do case "$d" in [A-Za-z~]) break ;; esac; done ;; esac
                  printf 'ignore' ;;
        esac
    else
        printf '%s' "$k"
    fi
}

