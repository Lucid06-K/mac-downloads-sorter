filter_count() { local f n=0; [ "$1" = only ] && f="$ONLY_FILE" || f="$EXCLUDE_FILE"; [ -r "$f" ] && n=$(grep -cvE '^[[:space:]]*(#|$)' "$f" 2>/dev/null); echo "${n:-0}"; }
