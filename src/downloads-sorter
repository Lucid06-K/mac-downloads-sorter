# full-screen sub-views (preview / undo / stats), each waits for a keypress
_pause() { printf '\n  %spress any key to return%s' "$DIM" "$R"; IFS= read -r -s -n 1 _ 2>/dev/null; }
do_preview() {
    printf '\033[H\033[2J'; printf '\n  %sPreview — where loose files would go%s  %s(nothing moved)%s\n\n' "$BLD" "$R" "$DIM" "$R"
    run_preview 2>/dev/null | sed 's/^/  /'; _pause; MSG="Preview shown (no changes made)"
}
_undo_row() { if [ "$1" -eq "$2" ]; then printf '  %s ▸ %s%s\n' "$REV" "$3" "$R"; else printf '     %s\n' "$3"; fi; }

# interactive undo: tick individual changes to revert, or revert whole runs;
# the history is a stack, so reverting the latest run reveals the previous one
# (keep going to step further back).
do_undo() {
    local focus=0 selected="" key i n show latest cnt nm oldp purge left m tg lrn nrows
    printf '\033[?25l'
    _undo_load                       # snapshot once so indices stay stable while you pick
    while :; do
        n=${#U_NEW[@]}; show=$n; [ "$show" -gt 50 ] && show=50
        latest="${U_STAMP[0]:-}"; lrn=0
        for i in "${!U_STAMP[@]}"; do [ "${U_STAMP[$i]}" = "$latest" ] && lrn=$((lrn+1)); done
        printf '\033[H\033[2J'
        printf '\n  %sUndo / revert changes%s  %s— newest first%s\n' "$BLD" "$R" "$DIM" "$R"
        printf '  %s\n' "${DIM}──────────────────────────────────────────────${R}"
        [ "$n" -eq 0 ] && printf '     %s(nothing to revert)%s\n' "$DIM" "$R"
        for (( i=0; i<show; i++ )); do
            case " $selected " in *" $i "*) m="[${GRN}✓${R}]" ;; *) m="[ ]" ;; esac
            nm=$(basename "${U_NEW[$i]}"); oldp="${U_OLD[$i]/#$HOME\//~/}"
            tg=""; [ "${U_STAMP[$i]}" = "$latest" ] && tg=" ${DIM}· latest${R}"
            if [ "$i" -eq "$focus" ]; then printf '  %s ▸ %s %-26.26s%s ← %s\n' "$REV" "$m" "$nm" "$R" "$oldp"
            else printf '     %s %-26.26s ← %s%s\n' "$m" "$nm" "$oldp" "$tg"; fi
        done
        [ "$n" -gt "$show" ] && printf '     %s…and %d older (revert runs to reach them)%s\n' "$DIM" "$((n-show))" "$R"
        printf '  %s\n' "${DIM}──────────────────────────────────────────────${R}"
        cnt=$(printf '%s' "$selected" | wc -w | tr -d ' ')
        _undo_row $show       "$focus" "Revert selected ($cnt)"
        _undo_row $((show+1)) "$focus" "Revert the latest run ($lrn file(s))"
        _undo_row $((show+2)) "$focus" "← Back"
        printf '\n  %s↑/↓ move · enter tick / run · esc back%s\n' "$DIM" "$R"
        nrows=$((show+3))
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + nrows - 1) % nrows )) ;;
            down|j) focus=$(( (focus + 1) % nrows )) ;;
            esc|q)  break ;;
            "")
                if [ "$focus" -lt "$show" ]; then
                    case " $selected " in
                        *" $focus "*) selected=$(printf '%s' "$selected" | tr ' ' '\n' | grep -vx "$focus" | tr '\n' ' ') ;;
                        *) selected="$selected $focus" ;;
                    esac
                elif [ "$focus" -eq "$show" ]; then
                    [ -n "$(printf '%s' "$selected" | tr -d ' ')" ] || { MSG="Nothing ticked"; continue; }
                    purge=$(mktemp)
                    for i in $selected; do _undo_one "${U_NEW[$i]}" "${U_OLD[$i]}"; printf '%s\n' "${U_NEW[$i]}" >> "$purge"; done
                    _undo_purge "$purge"; rm -f "$purge"; selected=""; focus=0; _undo_load
                elif [ "$focus" -eq $((show+1)) ]; then
                    [ "$n" -gt 0 ] || { MSG="Nothing to revert"; continue; }
                    purge=$(mktemp)
                    for i in "${!U_STAMP[@]}"; do [ "${U_STAMP[$i]}" = "$latest" ] && { _undo_one "${U_NEW[$i]}" "${U_OLD[$i]}"; printf '%s\n' "${U_NEW[$i]}" >> "$purge"; }; done
                    _undo_purge "$purge"; rm -f "$purge"; selected=""; focus=0; _undo_load
                else break; fi ;;
        esac
    done
    printf '\033[?25l'; MSG="Undo finished"
}
do_stats() {
    printf '\033[H\033[2J'; printf '\n  %sStats%s\n\n' "$BLD" "$R"
    run_stats 2>/dev/null; _pause; MSG=""
}

do_run() {
    if is_loaded; then
        launchctl kickstart "$TARGET" 2>/dev/null && MSG="Sort pass triggered" || MSG="Trigger failed (already running?)"
    else
        MSG="Sorter is OFF — turn it on first"
    fi
}

# activity log view: newest first, grouped under Today/Yesterday/date headers,
# "HH:MM  name  → Dest" columns; non-move lines (mv/osascript errors) in yellow
do_log() {
    local today ydy today_lbl ydy_lbl total
    today=$(date +%F); ydy=$(date -v-1d +%F)
    today_lbl="Today — $(date '+%e %b' | sed 's/^ *//')"
    ydy_lbl="Yesterday — $(date -v-1d '+%e %b' | sed 's/^ *//')"

    printf '\033[H\033[2J'
    printf '\n  %s\n' "${BLD}Downloads Sorter — activity log${R}"
    printf '  %s\n' "${DIM}────────────────────────────────────────────────────────────${R}"
    if [ ! -s "$LOG" ]; then
        printf '\n   %s(no activity yet)%s\n' "$DIM" "$R"
    else
        total=$(grep -c " moved: " "$LOG" 2>/dev/null)
        tail -n 40 "$LOG" | tail -r | awk \
            -v today="$today" -v ydy="$ydy" -v tlbl="$today_lbl" -v ylbl="$ydy_lbl" \
            -v dim="$DIM" -v grn="$GRN" -v bld="$BLD" -v yel="$YEL" -v r="$R" '
        {
            n = split($0, p, " -> ")
            if (n >= 2 && substr($0, 21, 7) == "moved: ") {
                dest = p[n]; sub(/\/$/, "", dest)
                d = substr($0, 1, 10); t = substr($0, 12, 5)
                name = substr($0, 28, length($0) - 27 - length(p[n]) - 4)
                if (d != lastd) {
                    lbl = (d == today) ? tlbl : (d == ydy) ? ylbl : d
                    printf "\n  %s%s%s\n", bld, lbl, r
                    lastd = d
                }
                if (length(name) > 38) name = substr(name, 1, 37) "…"
                printf "   %s%s%s  %-38s %s→ %s%s\n", dim, t, r, name, grn, dest, r
                moves++
            } else {
                printf "   %s⚠ %s%s\n", yel, $0, r
            }
        }
        END { if (!moves) printf "\n   %s(no moves in recent log)%s\n", dim, r }'
        printf '\n  %s\n' "${DIM}newest first · showing last 40 entries · $total moves in full log${R}"
        printf '  %s\n' "${DIM}full file: ~/Library/Logs/organize-downloads.log${R}"
    fi
    printf '\n  %s' "${DIM}press any key to return${R}"
    IFS= read -r -s -n 1 _ 2>/dev/null
}

# one keypress -> token (up/down/esc/empty-string for enter+space/literal char)
read_key() {
    local k rest
    IFS= read -r -s -n 1 k || return 1
    if [ "$k" = $'\033' ]; then
        IFS= read -r -s -n 2 -t 1 rest 2>/dev/null
        case "$rest" in
            '[A') printf 'up' ;;
            '[B') printf 'down' ;;
            *)    printf 'esc' ;;
        esac
    else
        printf '%s' "$k"
    fi
}

# help_topic <0-7> — prints one digestible, spaced-out section of the guide
help_topic() {
    case "$1" in
    0) cat <<'EOF'
  OVERVIEW — what it does & how it works

  Downloads Sorter watches your ~/Downloads folder and files new downloads
  into tidy category folders — the instant they land (folder-watching),
  plus an hourly safety-net pass.

  It only ever MOVES files: it never deletes or overwrites, and every
  move can be undone.

  How it decides where a file goes (first match wins):

       1.  Your custom rules    (Settings → Custom sorting rules)

       2.  Filename keywords     (screenshot / SCR-, invoice, statement…)

       3.  File extension

  Only loose files at the TOP of ~/Downloads are sorted — any folder you
  create yourself is left completely untouched.
EOF
    ;;
    1) cat <<'EOF'
  FEATURES (always on)

   •  Sorting
         files → categories by your rules, then keywords, then extension

   •  Archive
         files older than the archive age move into Archive/, keeping the
         same folder layout (default 30 days)

   •  Duplicate routing
         byte-identical files (same size + checksum) go to Duplicates/
         instead of "name (2)"

   •  Big-file quarantine
         files at/above your threshold (default 5 GB) go to Large Files/

   •  Screenshot dating
         "Screen Shot…" / "SCR-…"  →  "2026-06-14 Screenshot.png", by month

   •  Aging nudge
         a weekly heads-up if Archive holds files over a year old (never deletes)

   •  Notifications
         a banner after each sort, grouped by category

  Duplicates/ and Large Files/ are never auto-archived — they wait for you.
EOF
    ;;
    2) cat <<'EOF'
  SETTINGS & OPTIONS   (main menu → Settings ▸)

  Toggles:

       Notifications        Filename cleanup *      Aging nudge
       Duplicate routing    Screenshot dating       Metadata naming *
       Auto-unzip *         Auto-update *

  Values (arrow-key pickers):

       Auto-run interval    how often the safety-net timer fires (default 1h).
                            Real-time watching is always on, so downloads
                            still sort instantly regardless of this.

       Archive age          move-to-Archive threshold in days (default 30)

       Big files            size that sends a file to Large Files/ (default 5 GB)

  * = OPT-IN, OFF by default — nothing changes until you switch it on:

       Filename cleanup     tidies messy names (URL junk, random hashes,
                            trailing "copy"/"v2"); conservative + undoable
       Metadata naming      renames PDFs from their embedded title
       Auto-unzip           expands .zip into a same-named subfolder
       Auto-update          see the "Updating & security" topic
EOF
    ;;
    3) cat <<'EOF'
  EXCLUDE / ONLY-SORT FILTERS   (Settings ▸)

  Two multi-select checklists control what gets sorted — tick categories
  and/or type in file extensions:

   •  Exclude from sorting
         matching files are left where they are, and their folder is never
         created   (e.g. exclude Torrents + dmg)

   •  Only sort these
         if you pick any, ONLY matching files are sorted; everything else
         is left alone   (e.g. only Documents + Media)

  You can combine them (only Media, but exclude heic).

  Command line:

       dsort exclude Torrents dmg          dsort only Documents Media
       dsort exclude          (list)       dsort exclude clear
EOF
    ;;
    4) cat <<'EOF'
  CUSTOM SORTING RULES

  Send files matching a pattern to a folder of your choice — these override
  the built-in categories. Add and manage them, no typing in a file, from:

       Settings ▸   →   Custom sorting rules ▸

  Examples:

       *statement*    →   Documents/Finance

       *.dwg          →   3D & CAD

       *figma*        →   Design

  (They live in ~/.downloads-rules.conf if you'd rather edit by hand;
   list them anytime with  dsort rules.)
EOF
    ;;
    5) cat <<'EOF'
  UPDATING & SECURITY

   •  "Check for updates" on the main menu, or run:  dsort update

   •  dsort version   shows what you have installed

   •  Auto-update (Settings, OFF by default): when on, it checks once a day
      as you open the menu and installs verified updates automatically

  How updates stay safe:

       –  downloaded over HTTPS only, pinned to the project repo

       –  verified against published SHA-256 checksums (a mismatch aborts)

       –  syntax-checked before anything is replaced

       –  current scripts backed up to *.bak; never uses sudo
EOF
    ;;
    6) cat <<'EOF'
  SAFETY

   •  Never deletes or overwrites — uses a no-clobber move and adds " (2)"
      on a name clash

   •  Every move / rename / archive is logged to
      ~/Library/Logs/organize-downloads.log

   •  Undo lets you revert individual changes or whole runs, and keep
      stepping back through the history — it only moves files, never deletes

   •  Undo also covers PAST sortings: it reads the activity log and
      rebuilds revertable entries for files still sitting in their
      sorted folders, so older moves can be undone too

   •  The 30-day Archive only MOVES files (into Archive/); the aging nudge
      only reminds you. Nothing is ever auto-deleted.
EOF
    ;;
    7) cat <<'EOF'
  COMMANDS   (everything the menu does, scriptable)

       dsort                    open the menu
       dsort status             show every setting
       dsort version            dsort update

       dsort run                sort now
       dsort preview            dry run (no moves)
       dsort undo               move the last run's files back
       dsort find <name>        where did a download get filed?
       dsort stats              counts / sizes per category
       dsort rules              list custom rules
       dsort log [n]            recent activity

       dsort notify | cleannames | aging | duplicates   on|off
       dsort screenshotdate | metanames | autounzip | autoupdate   on|off

       dsort interval [secs|r]      archivedays [days|r]
       dsort graceperiod [secs|r]   largefiles [GB|r]
       dsort exclude / only  [items|clear]

       dsort on | off           enable/disable the whole sorter
EOF
    ;;
    esac
}

