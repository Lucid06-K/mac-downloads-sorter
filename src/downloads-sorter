is_loaded()    { launchctl print "$TARGET" >/dev/null 2>&1; }
notify_is_on() { [ ! -e "$NONOTIFY_FLAG" ]; }
detect_is_on() { [ -e "$DETECT_FLAG" ]; }   # heads-up when a download is detected (opt-in)
get_prune_scope() { local v=managed; [ -r "$PRUNE_SCOPE_FILE" ] && v=$(tr -dc 'a-z' < "$PRUNE_SCOPE_FILE" 2>/dev/null); case "$v" in user|all) echo "$v" ;; *) echo managed ;; esac; }
set_prune_scope() { case "$1" in managed|user|all) printf '%s\n' "$1" > "$PRUNE_SCOPE_FILE" ;; *) return 1 ;; esac; }
prunekeep_count() { local n=0; [ -r "$PRUNE_KEEP" ] && n=$(grep -cvE '^[[:space:]]*(#|$)' "$PRUNE_KEEP" 2>/dev/null); echo "${n:-0}"; }
pruneonly_count() { local n=0; [ -r "$PRUNE_ONLY" ] && n=$(grep -cvE '^[[:space:]]*(#|$)' "$PRUNE_ONLY" 2>/dev/null); echo "${n:-0}"; }
clean_is_on()  { [ -e "$CLEANFLAG" ]; }
aging_is_on()  { [ ! -e "$AGING_FLAG" ]; }   # weekly Archive nudge, default ON
digest_is_on() { [ -e "$DIGEST_FLAG" ]; }    # weekly activity digest, opt-in (default OFF)
dedup_is_on()  { [ ! -e "$DEDUP_FLAG" ]; }   # duplicates -> Duplicates/, default ON
ss_is_on()     { [ ! -e "$SS_FLAG" ]; }      # screenshot date-prefix + buckets, default ON
