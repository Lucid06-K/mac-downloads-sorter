            case "$2" in
                r|recommended|d|default) set_largefile "$RECOMMENDED_LARGEFILE_GB" && echo "Big-file quarantine: в‰Ґ $RECOMMENDED_LARGEFILE_GB GB (default)" ;;
                *) if set_largefile "$2"; then [ "$2" = 0 ] && echo "Big-file quarantine: OFF" || echo "Big-file quarantine: в‰Ґ $2 GB в†’ Large Files/"; else echo "Invalid (whole-number GB, 0 = off)." >&2; exit 1; fi ;;
            esac
        else
            lf=$(get_largefile); [ "$lf" = 0 ] && echo "Big-file quarantine: OFF (default $RECOMMENDED_LARGEFILE_GB GB)" || echo "Big-file quarantine: в‰Ґ $lf GB (default $RECOMMENDED_LARGEFILE_GB GB)"
        fi ;;
    screenshotdate)
        case "$2" in
            on)  rm -f "$SS_FLAG"; echo "Screenshot dating: ON" ;;
            off) touch "$SS_FLAG"; echo "Screenshot dating: OFF" ;;
            *)   ss_is_on && echo "Screenshot dating: ON" || echo "Screenshot dating: OFF" ;;
        esac ;;
    metanames)
        case "$2" in
            on)  touch "$META_FLAG"; echo "Metadata naming: ON" ;;
            off) rm -f "$META_FLAG"; echo "Metadata naming: OFF" ;;
            *)   meta_is_on && echo "Metadata naming: ON" || echo "Metadata naming: OFF" ;;
        esac ;;
    autounzip)
        case "$2" in
            on)  touch "$AUTOUNZIP_FLAG"; echo "Auto-unzip: ON" ;;
            off) rm -f "$AUTOUNZIP_FLAG"; echo "Auto-unzip: OFF" ;;
            *)   unzip_is_on && echo "Auto-unzip: ON" || echo "Auto-unzip: OFF" ;;
        esac ;;
    autoupdate)
        case "$2" in
            on)  touch "$AUTOUPDATE_FLAG"; echo "Auto-update: ON" ;;
            off) rm -f "$AUTOUPDATE_FLAG"; echo "Auto-update: OFF" ;;
            *)   autoupdate_on && echo "Auto-update: ON" || echo "Auto-update: OFF" ;;
        esac ;;
    interval)
        if [ -n "$2" ]; then
            case "$2" in
                r|recommended|d|default) set_interval "$RECOMMENDED_INTERVAL" && echo "Auto-run interval: every $(fmt_interval "$RECOMMENDED_INTERVAL") (default)" ;;
                *) if set_interval "$2"; then echo "Auto-run interval: every $(fmt_interval "$2")"; else echo "Invalid (digits only, minimum 60s)." >&2; exit 1; fi ;;
            esac
        else
            iv=$(get_interval)
            echo "Auto-run interval: every $(fmt_interval "$iv") (${iv:-unset}s)"
            echo "Default:       every $(fmt_interval "$RECOMMENDED_INTERVAL") (${RECOMMENDED_INTERVAL}s)"
        fi ;;
    archivedays)
        if [ -n "$2" ]; then
            case "$2" in
                r|recommended|d|default) set_archivedays "$RECOMMENDED_ARCHIVE_DAYS" && echo "Archive age: $RECOMMENDED_ARCHIVE_DAYS days (default)" ;;
                *) if set_archivedays "$2"; then echo "Archive age: $2 days"; else echo "Invalid (whole number в‰Ґ 1)." >&2; exit 1; fi ;;
            esac
        else
            echo "Archive age: $(get_archivedays) days (default $RECOMMENDED_ARCHIVE_DAYS)"
        fi ;;
    graceperiod|grace)
        if [ -n "$2" ]; then
            case "$2" in
                r|recommended|d|default) set_grace "$RECOMMENDED_GRACE" && echo "Grace period: $(fmt_grace "$RECOMMENDED_GRACE")" ;;
                *) if set_grace "$2"; then
                       if [ "$((10#$2))" -eq 0 ]; then rm -f "$DETECT_FLAG"; echo "Grace period: immediate (detected heads-up turned off)"
                       else echo "Grace period: $(fmt_grace "$2") before a download is sorted"; fi
                   else echo "Invalid (whole seconds, 0вЂ“2764799 / max 31 days; 0 = immediate)." >&2; exit 1; fi ;;
            esac
        else
            echo "Grace period: $(fmt_grace "$(get_grace)") (default ${RECOMMENDED_GRACE}s)"
        fi ;;
    recentcount|recent)
        if [ -n "$2" ]; then
            case "$2" in
                r|recommended|d|default) set_recent_count "$RECOMMENDED_RECENT" && echo "Recent activity: $RECOMMENDED_RECENT lines on the menu" ;;
                *) if set_recent_count "$2"; then [ "$2" = 0 ] && echo "Recent activity list: hidden" || echo "Recent activity: $2 line(s) on the menu"; else echo "Invalid (whole number 0вЂ“10)." >&2; exit 1; fi ;;
            esac
        else
            echo "Recent activity: $(get_recent_count) line(s) on the menu (default $RECOMMENDED_RECENT)"
        fi ;;
    preview)
        run_preview ;;
    undo)
        run_undo ;;
    stats)
        run_stats ;;
    rules)
        run_rules ;;
    find)
        shift; run_find "$@" ;;
    colors|colours)
        if [ -n "$3" ]; then
            _ok=0; for _c in "${COLOR_NAMES[@]}"; do [ "$_c" = "$3" ] && _ok=1; done
            if [ "$_ok" = 1 ]; then _colors_set "$2" "$3"; _colors_apply_now "$2" "$3"; echo "Folder colour: $2 в†’ $3"
            else echo "Unknown colour '$3'. Choose one of: ${COLOR_NAMES[*]}" >&2; exit 1; fi
        elif [ "$2" = clear ]; then : > "$COLORS_FILE"; echo "Folder colours cleared."
        elif [ -z "$2" ]; then
            if [ -s "$COLORS_FILE" ]; then echo "Folder colours:"; sed 's/|/ в†’ /' "$COLORS_FILE" 2>/dev/null | sed 's/^/  /'
            else echo "No folder colours set yet (dsort в†’ Settings в†’ Folder colours)."; fi
        else echo 'usage: dsort colours ["<Category>" <Colour>|clear]' >&2; exit 1; fi ;;
    cleanfolders|emptyfolders)
        case "$2" in
            managed|user|all) set_prune_scope "$2" && echo "Empty-folder cleanup scope: $2" ;;
            keep)  shift 2; if [ -n "$1" ]; then for a in "$@"; do printf '%s\n' "$a" >> "$PRUNE_KEEP"; done; echo "Blacklist += $*"
                   elif [ -s "$PRUNE_KEEP" ]; then echo "Never-delete (blacklist):"; grep -vE '^[[:space:]]*(#|$)' "$PRUNE_KEEP" | sed 's/^/  /'; else echo "Blacklist empty."; fi ;;
            keepclear) : > "$PRUNE_KEEP"; echo "Blacklist cleared." ;;
            only)  shift 2; if [ -n "$1" ]; then for a in "$@"; do printf '%s\n' "$a" >> "$PRUNE_ONLY"; done; echo "Whitelist += $*"
                   elif [ -s "$PRUNE_ONLY" ]; then echo "Only-delete (whitelist):"; grep -vE '^[[:space:]]*(#|$)' "$PRUNE_ONLY" | sed 's/^/  /'; else echo "Whitelist empty (all eligible)."; fi ;;
            onlyclear) : > "$PRUNE_ONLY"; echo "Whitelist cleared." ;;
            ""|status) echo "Empty-folder cleanup scope: $(get_prune_scope)  (blacklist $(prunekeep_count), whitelist $(pruneonly_count))" ;;
            *) echo 'usage: dsort cleanfolders [managed|user|all | keep [nameвЂ¦]|keepclear | only [nameвЂ¦]|onlyclear]' >&2; exit 1 ;;
        esac ;;
    exclude|only)
        kind="$1"; [ "$kind" = only ] && ff="$ONLY_FILE" || ff="$EXCLUDE_FILE"
        case "${2:-}" in
            clear) : > "$ff"; echo "$kind list cleared" ;;
            "")    if [ -s "$ff" ] && grep -qvE '^[[:space:]]*(#|$)' "$ff"; then
                       echo "$kind list (categories or extensions):"; grep -vE '^[[:space:]]*(#|$)' "$ff" | sed 's/^/  /'
                   else echo "$kind list is empty вЂ” set it from: dsort в†’ Settings"; fi ;;
            *)     shift
                   for a in "$@"; do
                       # lowercase a bare extension token (matches the TUI, which
                       # lowercases too) so `dsort exclude DMG` actually matches; leave
                       # category paths / multi-word names (with / or spaces) as typed.
                       case "$a" in
                           */*|*" "*) printf '%s\n' "$a" >> "$ff" ;;
                           *)         printf '%s\n' "$(printf '%s' "$a" | tr 'A-Z' 'a-z')" >> "$ff" ;;
                       esac
                   done
                   echo "added to $kind list: $*" ;;
        esac ;;
    version|--version|-v)
        echo "Downloads Sorter v$VERSION" ;;
    update)
        run_update ;;
    status)
        show_status ;;
    ui)
        ui_main ;;
    "")
        # bare invocation: interactive UI on a terminal, plain status otherwise
        if [ -t 0 ] && [ -t 1 ]; then ui_main; else show_status; fi ;;
    *)
        cat >&2 <<'USAGE'
Usage: dsort <command>   (bare = interactive UI)
  on | off            enable/disable the sorter
  status              text status of every setting
  run                 trigger a sort pass now
  preview             dry run вЂ” show where loose files would go (no moves)
  undo                move the last run's files back
  stats               file counts / sizes per category
  rules               list custom ~/.downloads-rules.conf rules
  exclude [.. |clear]  categories/extensions to never sort (bare = list)
  only [.. |clear]     sort ONLY these categories/extensions (bare = list)
  log [n]             last n log lines (default 15)
  notify on|off       "Downloads sorted" notifications
  detect on|off       opt-in heads-up when a download is detected (where + wait)
  cleannames on|off   opt-in filename cleanup
  aging on|off        weekly nudge for Archive files over a year old
  digest on|off       opt-in: weekly summary of what got sorted
  duplicates on|off   route byte-identical files to Duplicates/
  largefiles [n|d]    GB threshold for Large Files/ (0 = off, d = default)
  screenshotdate on|off  date-prefix screenshots + bucket by month
  metanames on|off    opt-in: rename PDFs from their embedded title
  autounzip on|off    opt-in: expand .zip into a same-named subfolder
  interval [secs|d]   show/set safety-net auto-run cadence (d = default)
  graceperiod [secs|d]  settle time before a download is sorted (0 = immediate, max 31 days)
  archivedays [n|d]   show/set Archive age in days (d = default)
  recentcount [0-10|d]  recent moves listed under the menu (0 = hide)
  find <name>         where a download got filed
  colours [args]      Finder colour tags on category folders (bare = list)
  cleanfolders [..]   empty-folder cleanup: managed|user|all, keep/only lists
  version             print the installed version
  update              download + install the latest version from GitHub
USAGE
        exit 1 ;;
esac
