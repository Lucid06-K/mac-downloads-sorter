# single-field integer entry, styled like form_grace so every numeric setting
# shares one in-menu UX вЂ” nothing drops to a raw command-line prompt.
# args: title  blurb  unit  current  default  min  max
# on save sets FORM_INT to the chosen value and returns 0; returns 1 if cancelled.
form_int() {
    local title="$1" blurb="$2" unit="$3" cur="$4" def="$5" min="$6" max="$7"
    local val focus=0 k nv fresh=1     # fresh: first digit replaces the shown value, then appends
    val=$((10#${cur:-0}))
    FORM_INT=""
    while :; do
        printf '\033[H\033[2J'
        printf '\n  %s%s%s  %sвЂ” %s%s\n' "$BLD" "$title" "$R" "$DIM" "$blurb" "$R"
        printf '  %sType a number; it replaces the value. Default %s.%s\n\n' "$DIM" "$def" "$R"
        if [ "$focus" -eq 0 ]; then printf '   %s в–ё %-8s [ %3s ] %s %s(%sвЂ“%s)%s\n' "$REV" "$unit" "$val" "$R" "$DIM" "$min" "$max" "$R"
        else printf '     %-8s [ %3s ]   %s(%sвЂ“%s)%s\n' "$unit" "$val" "$DIM" "$min" "$max" "$R"; fi
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        if [ "$focus" -eq 1 ]; then printf '  %s в–ё Save%s\n' "$REV" "$R"; else printf '     Save\n'; fi
        printf '\n  %sв†‘/в†“ field В· type digits В· вЊ« delete В· d default В· enter save В· esc cancel%s\n' "$DIM" "$R"
        k=$(read_key)
        case "$k" in
            up|k|down|j) focus=$(( (focus + 1) % 2 )) ;;
            [0-9])  if [ "$focus" -eq 0 ]; then
                        if [ "$fresh" = 1 ]; then nv="$k"; else nv=$(( val*10 + k )); fi
                        [ "$nv" -gt "$max" ] && nv="$k"; val=$nv; fresh=0
                    fi ;;
            $'\177'|$'\b') [ "$focus" -eq 0 ] && { val=$(( val / 10 )); fresh=0; } ;;
            d|D)    val=$def; fresh=1 ;;
            esc|q)  return 1 ;;
            "")     [ "$val" -lt "$min" ] && val=$min; FORM_INT="$val"; return 0 ;;
        esac
    done
}

