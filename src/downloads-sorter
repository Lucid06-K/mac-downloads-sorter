# arrow-key picker for the auto-run interval (presets, not free text)
pick_interval() {
    local opts=(900 1800 3600 10800 21600 43200 86400)
    local labels=("15 minutes" "30 minutes" "1 hour" "3 hours" "6 hours" "12 hours" "1 day")
    local cur sel=2 i k mark curmark
    cur=$(get_interval)
    for i in "${!opts[@]}"; do [ "${opts[$i]}" = "$cur" ] && sel="$i"; done
    while :; do
        printf '\033[H\033[2J'
        printf '\n  %sAuto-run interval%s\n' "$BLD" "$R"
        printf '  %sHow often the backup timer runs. New downloads still sort instantly%s\n' "$DIM" "$R"
        printf '  %svia folder-watching — this timer is only a safety net.%s\n\n' "$DIM" "$R"
        for i in "${!opts[@]}"; do
            mark="";    [ "${opts[$i]}" = "$RECOMMENDED_INTERVAL" ] && mark=" ${DIM}· recommended${R}"
            curmark=""; [ "${opts[$i]}" = "$cur" ] && curmark=" ${GRN}· current${R}"
            if [ "$i" -eq "$sel" ]; then
                printf '   %s ▸ %d. %-11s %s%s%s\n' "$REV" "$((i+1))" "${labels[$i]}" "$R" "$mark" "$curmark"
            else
                printf '     %d. %-11s%s%s\n' "$((i+1))" "${labels[$i]}" "$mark" "$curmark"
            fi
        done
        printf '\n  %s↑/↓ move · 1-7 jump · enter select · esc cancel%s' "$DIM" "$R"
        k=$(read_key)
        case "$k" in
            up|k)   sel=$(( (sel + ${#opts[@]} - 1) % ${#opts[@]} )) ;;
            down|j) sel=$(( (sel + 1) % ${#opts[@]} )) ;;
            [1-7])  sel=$((k-1)) ;;
            "")     set_interval "${opts[$sel]}" && MSG="Auto-run interval → every $(fmt_interval "${opts[$sel]}")" || MSG="Could not set interval"; return ;;
            q|esc)  MSG="Interval unchanged"; return ;;
        esac
    done
}

# arrow-key picker for the big-file quarantine threshold (0 = off)
pick_largefile() {
    local opts=(0 1 2 5 10 20)
    local labels=("Off — never quarantine" "1 GB" "2 GB" "5 GB" "10 GB" "20 GB")
    local cur sel=3 i k mark curmark
    cur=$(get_largefile)
    for i in "${!opts[@]}"; do [ "${opts[$i]}" = "$cur" ] && sel="$i"; done
    while :; do
