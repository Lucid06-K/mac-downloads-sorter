# interactive undo: tick individual changes to revert, or revert whole runs;
# the history is a stack, so reverting the latest run reveals the previous one
# (keep going to step further back).
do_undo() {
    local focus=0 selected="" key i n show latest cnt nm oldp purge left m tg lrn nrows
    printf '\033[?25l'
    _undo_load                       # snapshot once so indices stay stable while you pick
    while :; do
        n=${#U_NEW[@]}; show=$n; [ "$show" -gt 50 ] && show=50
        latest="${U_STAMP[0]:-}"; lrn=0
        for i in "${!U_STAMP[@]}"; do [ "${U_STAMP[$i]}" = "$latest" ] && lrn=$((lrn+1)); done
        printf '\033[H\033[2J'
        printf '\n  %sUndo / revert changes%s  %sвЂ” newest first%s\n' "$BLD" "$R" "$DIM" "$R"
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        [ "$n" -eq 0 ] && printf '     %s(nothing to revert)%s\n' "$DIM" "$R"
        for (( i=0; i<show; i++ )); do
            case " $selected " in *" $i "*) m="[${GRN}вњ“${R}]" ;; *) m="[ ]" ;; esac
            nm=$(basename "${U_NEW[$i]}"); oldp="${U_OLD[$i]/#$HOME\//~/}"
            tg=""; [ "${U_STAMP[$i]}" = "$latest" ] && tg=" ${DIM}В· latest${R}"
            if [ "$i" -eq "$focus" ]; then printf '  %s в–ё %s %-26.26s%s в†ђ %s\n' "$REV" "$m" "$nm" "$R" "$oldp"
            else printf '     %s %-26.26s в†ђ %s%s\n' "$m" "$nm" "$oldp" "$tg"; fi
        done
        [ "$n" -gt "$show" ] && printf '     %sвЂ¦and %d older (revert runs to reach them)%s\n' "$DIM" "$((n-show))" "$R"
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        cnt=$(printf '%s' "$selected" | wc -w | tr -d ' ')
        _undo_row $show       "$focus" "Revert selected ($cnt)"
        _undo_row $((show+1)) "$focus" "Revert the latest run ($lrn file(s))"
        _undo_row $((show+2)) "$focus" "в†ђ Back"
        [ -n "$MSG" ] && { printf '\n  %s%s%s\n' "$GRN" "$MSG" "$R"; MSG=""; }   # show feedback (e.g. "Nothing ticked") for one frame
        printf '\n  %sв†‘/в†“ move В· enter tick / run В· esc back%s\n' "$DIM" "$R"
        nrows=$((show+3))
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + nrows - 1) % nrows )) ;;
            down|j) focus=$(( (focus + 1) % nrows )) ;;
            esc|q)  break ;;
            "")
                if [ "$focus" -lt "$show" ]; then
                    case " $selected " in
                        *" $focus "*) selected=$(printf '%s' "$selected" | tr ' ' '\n' | grep -vx "$focus" | tr '\n' ' ') ;;
                        *) selected="$selected $focus" ;;
                    esac
                elif [ "$focus" -eq "$show" ]; then
                    [ -n "$(printf '%s' "$selected" | tr -d ' ')" ] || { MSG="Nothing ticked"; continue; }
                    purge=$(mktemp)
                    for i in $selected; do _undo_one "${U_NEW[$i]}" "${U_OLD[$i]}"; printf '%s\n' "${U_NEW[$i]}" >> "$purge"; done
                    _undo_purge "$purge"; rm -f "$purge"; selected=""; focus=0; _undo_load
                elif [ "$focus" -eq $((show+1)) ]; then
                    [ "$n" -gt 0 ] || { MSG="Nothing to revert"; continue; }
                    purge=$(mktemp)
                    for i in "${!U_STAMP[@]}"; do [ "${U_STAMP[$i]}" = "$latest" ] && { _undo_one "${U_NEW[$i]}" "${U_OLD[$i]}"; printf '%s\n' "${U_NEW[$i]}" >> "$purge"; }; done
                    _undo_purge "$purge"; rm -f "$purge"; selected=""; focus=0; _undo_load
                else break; fi ;;
        esac
    done
    printf '\033[?25l'; MSG="Undo finished"
}
