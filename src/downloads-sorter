#
# dsort — control the com.downloads-sorter.agent launchd agent.
#
# Run bare for an interactive UI (arrow keys + enter, or s/n/r/l/q shortcuts).
# Scriptable subcommands:
#   dsort on|off          enable/disable the sorter (persists across restarts)
#   dsort status          one-shot text status
#   dsort run             trigger a sort pass now
#   dsort log [n]         last n log lines (default 15)
#   dsort notify on|off   toggle "Downloads sorted" notifications
#   dsort cleannames on|off   toggle opt-in filename cleanup
#   dsort interval [secs]     show/set the safety-net auto-run interval
#
# The sorter itself lives in organize_downloads.sh next to this file.

LABEL="com.downloads-sorter.agent"
TARGET="gui/$(id -u)/$LABEL"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOG="$HOME/Library/Logs/organize-downloads.log"
NONOTIFY_FLAG="$HOME/Library/Scripts/organize_downloads.nonotify"
CLEANFLAG="$HOME/Library/Scripts/organize_downloads.cleannames"
AGEFILE="$HOME/Library/Scripts/organize_downloads.archivedays"
GRACEFILE="$HOME/Library/Scripts/organize_downloads.graceperiod"
AGING_FLAG="$HOME/Library/Scripts/organize_downloads.noaging"
DEDUP_FLAG="$HOME/Library/Scripts/organize_downloads.noduplicates"
LFFILE="$HOME/Library/Scripts/organize_downloads.largefilegb"
SS_FLAG="$HOME/Library/Scripts/organize_downloads.noscreenshotdate"
META_FLAG="$HOME/Library/Scripts/organize_downloads.metanames"
AUTOUNZIP_FLAG="$HOME/Library/Scripts/organize_downloads.autounzip"
EXCLUDE_FILE="$HOME/Library/Scripts/organize_downloads.exclude"
ONLY_FILE="$HOME/Library/Scripts/organize_downloads.only"
AUTOUPDATE_FLAG="$HOME/Library/Scripts/organize_downloads.autoupdate"
UPDATE_STAMP="$HOME/Library/Scripts/.organize_downloads.update_check"
UNDO_FILE="$HOME/Library/Scripts/organize_downloads.lastrun"
HISTORY_FILE="$HOME/Library/Scripts/organize_downloads.history"
SORTER="$HOME/Library/Scripts/organize_downloads.sh"
FILTER_CATS=( "Screenshots" "Media" "Documents" "Compressed Files" "Installers & Apps" "Disk Images" "Code & Scripts" "Invoices & Receipts" "Design" "Fonts" "3D & CAD" "Torrents" "Data" "Calendars & Contacts" "Misc" )
VERSION="1.0.9"
REPO_RAW="https://raw.githubusercontent.com/Lucid06-K/mac-downloads-sorter/main"
SELF="$HOME/Library/Scripts/downloads-sorter"
RECOMMENDED_INTERVAL=3600       # hourly — WatchPaths does the real work; this is just a backup
RECOMMENDED_ARCHIVE_DAYS=30     # sweep files older than this into Archive/
RECOMMENDED_LARGEFILE_GB=5      # files >= this go to Large Files/ for review
RECOMMENDED_GRACE=60            # seconds to let a download settle before sorting

R=$'\033[0m'; REV=$'\033[7m'; DIM=$'\033[2m'; GRN=$'\033[32m'; BLD=$'\033[1m'; YEL=$'\033[33m'

is_loaded()    { launchctl print "$TARGET" >/dev/null 2>&1; }
notify_is_on() { [ ! -e "$NONOTIFY_FLAG" ]; }
clean_is_on()  { [ -e "$CLEANFLAG" ]; }
aging_is_on()  { [ ! -e "$AGING_FLAG" ]; }   # weekly Archive nudge, default ON
dedup_is_on()  { [ ! -e "$DEDUP_FLAG" ]; }   # duplicates -> Duplicates/, default ON
ss_is_on()     { [ ! -e "$SS_FLAG" ]; }      # screenshot date-prefix + buckets, default ON
meta_is_on()   { [ -e "$META_FLAG" ]; }      # PDF metadata naming, opt-in OFF
unzip_is_on()  { [ -e "$AUTOUNZIP_FLAG" ]; } # auto-unzip .zip, opt-in OFF
filter_count() { local f; [ "$1" = only ] && f="$ONLY_FILE" || f="$EXCLUDE_FILE"; [ -r "$f" ] && grep -cvE '^[[:space:]]*(#|$)' "$f" 2>/dev/null || echo 0; }
rules_count()  { [ -r "$HOME/.downloads-rules.conf" ] && grep -hcE '\->|→' "$HOME/.downloads-rules.conf" 2>/dev/null || echo 0; }
autoupdate_on() { [ -e "$AUTOUPDATE_FLAG" ]; }   # auto-install updates, opt-in OFF
get_largefile() {
    local v=""
    [ -r "$LFFILE" ] && v=$(tr -dc '0-9' < "$LFFILE" 2>/dev/null)
    [ -n "$v" ] && echo "$v" || echo "$RECOMMENDED_LARGEFILE_GB"
}
set_largefile() { case "$1" in *[!0-9]*|"") return 1 ;; esac; printf '%s\n' "$1" > "$LFFILE"; }

sorter_on()  { launchctl enable "$TARGET"; launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null; }
sorter_off() { launchctl bootout "$TARGET" 2>/dev/null; launchctl disable "$TARGET"; }

# read/format/set the launchd StartInterval (the safety-net auto-run cadence)
get_interval() {
    local v=""
    [ -r "$PLIST" ] && v=$(/usr/libexec/PlistBuddy -c "Print :StartInterval" "$PLIST" 2>/dev/null)
    case "$v" in ""|*[!0-9]*) echo "" ;; *) echo "$v" ;; esac   # only ever a clean integer (or empty)
}
fmt_interval() {
    local s="$1"
    if   [ -z "$s" ] || [ "$s" -le 0 ] 2>/dev/null;            then echo "off"
    elif [ "$s" -ge 86400 ] && [ $((s % 86400)) -eq 0 ]; then echo "$((s/86400))d"
    elif [ "$s" -ge 3600 ]  && [ $((s % 3600))  -eq 0 ]; then echo "$((s/3600))h"
    elif [ "$s" -ge 60 ]    && [ $((s % 60))    -eq 0 ]; then echo "$((s/60))m"
    else echo "${s}s"; fi
}
set_interval() {
    local secs="$1"
    case "$secs" in ""|*[!0-9]*) return 1 ;; esac     # digits only
    [ "$secs" -lt 60 ] && return 1                    # launchd throttles below this anyway
    /usr/libexec/PlistBuddy -c "Set :StartInterval $secs" "$PLIST" 2>/dev/null \
        || /usr/libexec/PlistBuddy -c "Add :StartInterval integer $secs" "$PLIST" 2>/dev/null || return 1
    # reload so launchd picks up the change — but only if it's currently running,
    # so we never silently turn a disabled sorter back on
    if is_loaded; then
        launchctl bootout "$TARGET" 2>/dev/null
        launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null
    fi
}

# archive age (in days); stored in AGEFILE, default RECOMMENDED_ARCHIVE_DAYS
get_archivedays() {
    local v=""
    [ -r "$AGEFILE" ] && v=$(tr -dc '0-9' < "$AGEFILE" 2>/dev/null)
    [ -n "$v" ] && echo "$v" || echo "$RECOMMENDED_ARCHIVE_DAYS"
}
set_archivedays() {
    local d="$1"
    case "$d" in ""|*[!0-9]*) return 1 ;; esac
    [ "$d" -lt 1 ] && return 1
    printf '%s\n' "$d" > "$AGEFILE"
}

# grace period (in seconds) before a freshly-modified file is sorted; stored in
# GRACEFILE, default RECOMMENDED_GRACE. 0 = sort immediately. Capped at 1 day.
get_grace() {
    local v=""
    [ -r "$GRACEFILE" ] && v=$(tr -dc '0-9' < "$GRACEFILE" 2>/dev/null)
    [ -n "$v" ] && echo "$v" || echo "$RECOMMENDED_GRACE"
}
set_grace() {
    local s="$1"
    case "$s" in ""|*[!0-9]*) return 1 ;; esac
    [ "$s" -gt 86400 ] && return 1
    printf '%s\n' "$s" > "$GRACEFILE"
}
# friendly seconds label: "0s (immediate)", "45s", "2m", "1m 30s"
fmt_grace() {
    local s="$1"
    [ "$s" -eq 0 ] 2>/dev/null && { echo "0s (immediate)"; return; }
    if [ "$s" -lt 120 ]; then echo "${s}s"
    elif [ $((s % 60)) -eq 0 ]; then echo "$((s/60))m"
    else echo "$((s/60))m $((s%60))s"; fi
}

# --- undo history (a stack of moves) ------------------------------------
# Backfill the undo stack from the activity log so sortings that predate the
# history file — or any move only the log recorded — become revertable. We
# reconstruct old<TAB>new from `moved:`/`duplicate:` lines, pairing a same-second
# `renamed:` line so dated screenshots / cleaned names restore to their original
# name. Conservative and idempotent by design:
#   • a record is imported only if its destination file is on disk right now
#   • a destination already in the history is never added twice (keyed by dest)
#   • `archived:` lines are skipped — the log doesn't record the origin folder
#   • collision-suffixed names (" (2)") aren't in the log, so those are left be
# Worst case a reconstructed record matches nothing and is skipped at revert
# time: _undo_one only ever moves a file back, it never deletes or clobbers.
_undo_import_log() {
    [ -r "$LOG" ] || return 0
    local dir="$HOME/Downloads" seen merged line ts rest verb payload base reldir
    local oldbase newpath oldpath epoch prev_ts="" prev_old="" prev_new=""
    seen=$(mktemp); merged=$(mktemp)
    [ -r "$HISTORY_FILE" ] && cut -f3 "$HISTORY_FILE" 2>/dev/null > "$seen"
    while IFS= read -r line || [ -n "$line" ]; do
        [ ${#line} -gt 20 ] || continue
        ts="${line:0:19}"; rest="${line:20}"
        verb="${rest%%:*}"; payload="${rest#*: }"
        case "$verb" in
            renamed) prev_ts="$ts"; prev_new="${payload##* -> }"; prev_old="${payload% -> *}"; continue ;;
            moved|duplicate) : ;;
            *) prev_ts=""; continue ;;
        esac
        base="${payload% -> *}"; reldir="${payload##* -> }"; reldir="${reldir%/}"
        [ -n "$base" ] && [ -n "$reldir" ] || { prev_ts=""; continue; }
        newpath="$dir/$reldir/$base"
        if [ "$prev_ts" = "$ts" ] && [ "$prev_new" = "$base" ]; then oldbase="$prev_old"; else oldbase="$base"; fi
        oldpath="$dir/$oldbase"; prev_ts=""
        [ -e "$newpath" ] || continue
        grep -qxF -- "$newpath" "$seen" 2>/dev/null && continue
        epoch=$(date -j -f "%Y-%m-%d %H:%M:%S" "$ts" +%s 2>/dev/null)
        case "$epoch" in ''|*[!0-9]*) continue ;; esac
        printf '%s\t%s\t%s\n' "$epoch" "$oldpath" "$newpath" >> "$merged"
        printf '%s\n' "$newpath" >> "$seen"
    done < "$LOG"
    if [ -s "$merged" ]; then
        cat "$merged" >> "$HISTORY_FILE"
        sort -t$'\t' -k1,1n "$HISTORY_FILE" -o "$HISTORY_FILE" 2>/dev/null
        if [ "$(wc -l < "$HISTORY_FILE" 2>/dev/null || echo 0)" -gt 3000 ]; then
            tail -n 2000 "$HISTORY_FILE" > "$HISTORY_FILE.tmp" 2>/dev/null && mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"
        fi
    fi
    rm -f "$seen" "$merged"
}
# Prepare the stack once per process: migrate the legacy single-run file (older
# installs) and backfill from the log. Guarded so repeated _undo_load calls
# (e.g. after each revert) don't re-scan the log.
_undo_prepare() {
    [ "${_undo_prepared:-0}" = 1 ] && return 0
    _undo_prepared=1
    if [ -s "$UNDO_FILE" ] && [ ! -e "$HISTORY_FILE" ]; then
        local l; while IFS= read -r l; do [ -n "$l" ] && printf '0\t%s\n' "$l" >> "$HISTORY_FILE"; done < "$UNDO_FILE"
        rm -f "$UNDO_FILE"
    fi
    _undo_import_log
}
# load history newest-first into U_STAMP / U_OLD / U_NEW
_undo_load() {
    _undo_prepare
    U_STAMP=(); U_OLD=(); U_NEW=()
    [ -r "$HISTORY_FILE" ] || return 0
    local s o n
    while IFS=$'\t' read -r s o n; do
        [ -n "$o" ] && [ -n "$n" ] || continue
        U_STAMP+=("$s"); U_OLD+=("$o"); U_NEW+=("$n")
    done < <(tail -r "$HISTORY_FILE" 2>/dev/null)
}
# move one file back (new -> old). never deletes; never clobbers an occupied origin
_undo_one() {
    local new="$1" old="$2"
    [ -e "$new" ] || return 1               # already gone
    [ -e "$old" ] && return 2               # something is back at the origin — skip
    mkdir -p "$(dirname "$old")"
    mv -n "$new" "$old" 2>/dev/null && return 0 || return 1
}
# drop history lines whose 'new' path appears (one per line) in file $1
_undo_purge() {
    [ -r "$HISTORY_FILE" ] || return 0
    local s o n
    : > "$HISTORY_FILE.tmp"
    while IFS=$'\t' read -r s o n; do
        grep -qxF -- "$n" "$1" 2>/dev/null && continue
        printf '%s\t%s\t%s\n' "$s" "$o" "$n" >> "$HISTORY_FILE.tmp"
    done < "$HISTORY_FILE"
    mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"
}
_undo_runs() {
    [ -r "$HISTORY_FILE" ] || { echo 0; return; }
    cut -f1 "$HISTORY_FILE" 2>/dev/null | sort -u | sed '/^$/d' | wc -l | tr -d ' '
}

# `dsort undo`: revert the most recent run; repeat to keep stepping back.
run_undo() {
    _undo_load        # _undo_prepare (inside) migrates legacy state + backfills past sorts from the log
    [ "${#U_NEW[@]}" -gt 0 ] || { echo "Nothing to undo."; return; }
    local latest="${U_STAMP[0]}" n=0 skip=0 i purge; purge=$(mktemp)
    for i in "${!U_NEW[@]}"; do
        [ "${U_STAMP[$i]}" = "$latest" ] || continue
        if _undo_one "${U_NEW[$i]}" "${U_OLD[$i]}"; then n=$((n+1)); else skip=$((skip+1)); fi
        printf '%s\n' "${U_NEW[$i]}" >> "$purge"
    done
    _undo_purge "$purge"; rm -f "$purge"
    local left; left=$(_undo_runs)
    echo "Reverted $n file(s) from the most recent run$([ "$skip" -gt 0 ] && echo " ($skip skipped)")."
    [ "${left:-0}" -gt 0 ] && echo "↩  Run 'dsort undo' again to revert the previous run — $left earlier run(s) left."
}

# dry-run preview and stats reuse the sorter's own classify()/MANAGED_DIRS by
# sourcing it inside a subshell (its run-guard means sourcing has no side effects)
run_preview() ( source "$SORTER" >/dev/null 2>&1 && preview )
run_stats() (
    source "$SORTER" >/dev/null 2>&1 || { echo "Could not load sorter."; exit 1; }
    local d n sz arch
    printf '  %sFiles by category%s\n' "$BLD" "$R"
    for d in "${MANAGED_DIRS[@]}"; do
        [ -d "$DIR/$d" ] || continue
        n=$(find "$DIR/$d" -type f ! -name '.*' 2>/dev/null | wc -l | tr -d ' ')
        [ "${n:-0}" -eq 0 ] && continue
        sz=$(du -sh "$DIR/$d" 2>/dev/null | cut -f1)
        printf '   %-24s %5s files  %7s\n' "$d" "$n" "$sz"
    done
    if [ -d "$DIR/Archive" ]; then
        arch=$(find "$DIR/Archive" -type f ! -name '.*' 2>/dev/null | wc -l | tr -d ' ')
        sz=$(du -sh "$DIR/Archive" 2>/dev/null | cut -f1)
        printf '   %s%-24s %5s files  %7s%s\n' "$DIM" "Archive (all)" "$arch" "$sz" "$R"
    fi
    local last
    last=$(grep -hE ' (moved|archived|renamed): ' "$LOG" 2>/dev/null | tail -n1 | cut -c1-19)
    printf '\n   Last activity: %s\n' "${last:-(none yet)}"
)
# list the user's custom rules exactly as the sorter parses them
run_rules() (
    rf="$HOME/.downloads-rules.conf"
    if [ ! -r "$rf" ]; then
        echo "No custom rules yet. Create $rf with lines like:"
        echo "    *statement*   -> Documents/Finance"
        echo "    *.dwg         -> 3D & CAD"
        echo "(arrow may be -> or →; rules are checked before the built-in categories)"
        exit 0
    fi
    source "$SORTER" >/dev/null 2>&1
    if [ "${#RULE_PAT[@]}" -eq 0 ]; then echo "Rules file present but no valid rules parsed."; exit 0; fi
    echo "Custom rules (checked before built-ins):"
    for i in "${!RULE_PAT[@]}"; do printf '   %-28s → %s\n' "${RULE_PAT[$i]}" "${RULE_DEST[$i]}"; done
)

# `dsort find <text>`: where did a download go? Case-insensitive substring search
# across ~/Downloads (every sorted folder + Archive). Shows each hit's folder,
# flags anything still loose at the top, and prints a ready-to-run reveal command.
run_find() {
    local q="$*" dir="$HOME/Downloads" count=0 line rel base sub first=""
    [ -n "$q" ] || { echo "Usage: dsort find <part of a filename>"; return 1; }
    [ -d "$dir" ] || { echo "No ~/Downloads folder found."; return 1; }
    printf '  %sWhere did it go?%s  matches for "%s"\n\n' "$BLD" "$R" "$q"
    while IFS= read -r line; do
        rel="${line#"$dir"/}"; base="${rel##*/}"; sub="${rel%/*}"
        if [ "$sub" = "$rel" ]; then
            printf '   %s\n        %s· still loose at the top of Downloads (not sorted yet)%s\n' "$base" "$DIM" "$R"
        else
            printf '   %s\n        %sin%s  %s/\n' "$base" "$DIM" "$R" "$sub"
        fi
        [ -z "$first" ] && first="$line"
        count=$((count+1))
    done < <(find "$dir" -type f ! -path '*/.*' -iname "*$q*" 2>/dev/null | sort)
    if [ "$count" -eq 0 ]; then
        printf '   %sNothing matching "%s" under ~/Downloads.%s\n' "$DIM" "$q" "$R"; return 0
    fi
    if [ "$count" -eq 1 ]; then
        printf '\n  %sReveal it in Finder:%s  open -R "%s"\n' "$DIM" "$R" "$first"
    else
        printf '\n  %s%d matches. Reveal one in Finder with:%s  open -R "<path above>"\n' "$DIM" "$count" "$R"
    fi
}

# live "Folder categories" view: two columns (category | what routes there),
# wrapped to the terminal width, plus your custom rules. Reads the real table.
render_categories() (
    source "$SORTER" >/dev/null 2>&1
    local W left cat exts wrapped ln first i
    W=$(tput cols 2>/dev/null); case "$W" in ''|*[!0-9]*) W=80 ;; esac; [ "$W" -lt 56 ] && W=80
    left=22; rightw=$(( W - left - 6 )); [ "$rightw" -lt 24 ] && rightw=24
    printf '\n  %sFolder categories%s   %s— where each kind of file is filed%s\n\n' "$BLD" "$R" "$DIM" "$R"
    category_map | while IFS='|' read -r cat exts; do
        wrapped=$(printf '%s' "$exts" | fold -s -w "$rightw")
        first=1
        while IFS= read -r ln; do
            if [ "$first" = 1 ]; then printf '  %s%-*s%s %s\n' "$BLD" "$left" "$cat" "$R" "$ln"; first=0
            else printf '  %-*s %s\n' "$left" "" "$ln"; fi
        done < <(printf '%s\n' "$wrapped")
    done
    if [ "${#RULE_PAT[@]}" -gt 0 ]; then
        printf '\n  %sYour custom rules%s   %s(checked first — override the above)%s\n\n' "$BLD" "$R" "$DIM" "$R"
        for i in "${!RULE_PAT[@]}"; do printf '  %s%-*s%s →  %s\n' "$GRN" "$left" "${RULE_PAT[$i]}" "$R" "${RULE_DEST[$i]}"; done
    else
        printf '\n  %sNo custom rules yet — add some in Settings → Custom sorting rules.%s\n' "$DIM" "$R"
    fi
    echo
)

# full-screen Folder-categories view (paged through less, since the list is long)
do_categories() {
    if command -v less >/dev/null 2>&1; then render_categories | less -R
    else printf '\033[H\033[2J'; render_categories; _pause; fi
    printf '\033[?25l'; MSG=""
}

# fetch the latest scripts from the repo and install them. Security measures:
#  • HTTPS only, even across redirects (--proto / --proto-redir '=https')
#  • pinned to one repo URL — no arbitrary hosts
#  • SHA-256 integrity check against the repo's published SHA256SUMS
#  • syntax-checked (bash -n) before anything is replaced
#  • backs up the current scripts to *.bak (easy rollback)
#  • user-space only (no sudo); preserves THIS install's launch-agent label
# Returns 0 if updated or already current, 1 on any failure (leaves files intact).
CURL_SAFE='curl -fsSL --proto =https --proto-redir =https --max-redirs 3'
run_update() {
    command -v curl >/dev/null 2>&1 || { echo "curl is required for updates."; return 1; }
    local tmp newver cur_label
    echo "Checking github.com/Lucid06-K/mac-downloads-sorter …"
    newver=$($CURL_SAFE "$REPO_RAW/VERSION" 2>/dev/null | tr -dc '0-9.')
    [ -n "$newver" ] || { echo "Couldn't reach the update server (check your connection)."; return 1; }
    echo "  installed: v$VERSION    latest: v$newver"
    [ "$newver" = "$VERSION" ] && { echo "You're already up to date."; return 0; }
    tmp=$(mktemp -d)
    $CURL_SAFE "$REPO_RAW/src/organize_downloads.sh" -o "$tmp/organize_downloads.sh" 2>/dev/null
    $CURL_SAFE "$REPO_RAW/src/downloads-sorter"       -o "$tmp/downloads-sorter"       2>/dev/null
    $CURL_SAFE "$REPO_RAW/SHA256SUMS"                 -o "$tmp/SHA256SUMS"             2>/dev/null
    if [ ! -s "$tmp/organize_downloads.sh" ] || [ ! -s "$tmp/downloads-sorter" ]; then
        echo "Download failed — nothing changed."; rm -rf "$tmp"; return 1; fi
    # integrity: the downloaded bytes must match the repo's published checksums
    if [ -s "$tmp/SHA256SUMS" ]; then
        if ! ( cd "$tmp" && shasum -a 256 -c SHA256SUMS >/dev/null 2>&1 ); then
            echo "✗ Integrity check FAILED — download didn't match published checksums. Aborting."
            rm -rf "$tmp"; return 1
        fi
        echo "  ✓ checksums verified"
    else
        echo "✗ Couldn't fetch checksums — refusing to install unverified code."
        rm -rf "$tmp"; return 1
    fi
    # corruption guard (after integrity, before we touch anything)
    if ! bash -n "$tmp/organize_downloads.sh" || ! bash -n "$tmp/downloads-sorter"; then
        echo "✗ Downloaded files failed a syntax check — nothing changed."; rm -rf "$tmp"; return 1; fi
    # keep this machine's launch-agent label (done after verification, so it can't affect the hash)
    cur_label=$(grep -m1 '^LABEL=' "$SELF" 2>/dev/null)
    [ -n "$cur_label" ] && sed -i '' "s|^LABEL=.*|$cur_label|" "$tmp/downloads-sorter"
    cp "$SORTER" "$SORTER.bak" 2>/dev/null; cp "$SELF" "$SELF.bak" 2>/dev/null
    install -m 0755 "$tmp/organize_downloads.sh" "$SORTER"
    install -m 0755 "$tmp/downloads-sorter" "$SELF"
    rm -rf "$tmp"
    echo "Updated v$VERSION → v$newver ✓   (previous versions saved as *.bak)"
    echo "Re-open the menu (or your shell) to use the new version."
}

# called when the menu opens: if auto-update is ON and a day has passed, check
# and (if newer) install via the same verified path as a manual update.
maybe_autoupdate() {
    autoupdate_on || return 0
    command -v curl >/dev/null 2>&1 || return 0
    local last now newver
    if [ -f "$UPDATE_STAMP" ]; then
        last=$(stat -f %m "$UPDATE_STAMP" 2>/dev/null || echo 0); now=$(date +%s)
        [ $((now - last)) -lt 86400 ] && return 0      # checked within the last day
    fi
    touch "$UPDATE_STAMP"
    newver=$($CURL_SAFE "$REPO_RAW/VERSION" 2>/dev/null | tr -dc '0-9.')
    [ -n "$newver" ] && [ "$newver" != "$VERSION" ] || return 0
    echo "Auto-update: a newer version (v$newver) is available — installing…"
    run_update
    printf '\n  press any key to open the menu… '; IFS= read -r -s -n 1 _ 2>/dev/null
}

# full-screen "Check for updates" view (manual button)
do_update() {
    printf '\033[H\033[2J'; printf '\n  %sCheck for updates%s\n\n' "$BLD" "$R"
    run_update
    printf '\n  %spress any key to return%s' "$DIM" "$R"; IFS= read -r -s -n 1 _ 2>/dev/null
    printf '\033[?25l'; MSG=""
}

show_status() {
    echo "Downloads Sorter v$VERSION"
    local iv ad; iv=$(get_interval); ad=$(get_archivedays)
    if is_loaded; then echo "Sorter: ON (loaded)"; else echo "Sorter: OFF (not loaded)"; fi
    notify_is_on && echo "Notifications: ON" || echo "Notifications: OFF"
    clean_is_on  && echo "Filename cleanup: ON" || echo "Filename cleanup: OFF"
    aging_is_on  && echo "Aging nudge (weekly, Archive >1yr): ON" || echo "Aging nudge: OFF"
    dedup_is_on  && echo "Duplicate routing: ON (identical → Duplicates/)" || echo "Duplicate routing: OFF"
    if [ "$(get_largefile)" = 0 ]; then echo "Big-file quarantine: OFF"
    else echo "Big-file quarantine: ≥ $(get_largefile) GB → Large Files/ (recommended $RECOMMENDED_LARGEFILE_GB)"; fi
    ss_is_on    && echo "Screenshot dating: ON (date-prefix + monthly folders)" || echo "Screenshot dating: OFF"
    meta_is_on  && echo "Metadata naming (PDF titles): ON" || echo "Metadata naming: OFF (opt-in)"
    unzip_is_on && echo "Auto-unzip (.zip): ON" || echo "Auto-unzip: OFF (opt-in)"
    autoupdate_on && echo "Auto-update: ON (checks daily, verified install)" || echo "Auto-update: OFF (manual: dsort update)"
    if [ -r "$HOME/.downloads-rules.conf" ]; then
        echo "Custom rules: $(grep -vE '^[[:space:]]*#' "$HOME/.downloads-rules.conf" | grep -cE '\->|→') active (dsort rules)"
    else echo "Custom rules: none (~/.downloads-rules.conf)"; fi
    ex=$(filter_count exclude); on=$(filter_count only)
    if [ "$on" -gt 0 ]; then echo "Sorting filter: ONLY sorting $on selected type(s) (+ $ex excluded)"
    elif [ "$ex" -gt 0 ]; then echo "Sorting filter: excluding $ex type(s)"
    else echo "Sorting filter: off (sorting everything)"; fi
    echo "Auto-run interval: every $(fmt_interval "$iv") (${iv:-unset}s) — recommended every $(fmt_interval "$RECOMMENDED_INTERVAL") (${RECOMMENDED_INTERVAL}s)"
    echo "Archive age: $ad days — recommended $RECOMMENDED_ARCHIVE_DAYS"
    echo "Grace period: $(fmt_grace "$(get_grace)") — recommended ${RECOMMENDED_GRACE}s"
    echo "Recent activity:"
    tail -n 5 "$LOG" 2>/dev/null || echo "  (no log yet)"
}

# ---------- interactive UI ----------

# compact "HH:MM  file → Dest" lines for the activity panel
recent_lines() {
    tail -n 3 "$LOG" 2>/dev/null |
        sed -E -e 's/^[0-9-]+ ([0-9]{2}:[0-9]{2}):[0-9]{2} moved: /\1  /' \
               -e 's| -> (.*)/$| → \1|' | cut -c 1-60
}

# the number-shortcut for a row: 1-9 for rows 0-8, 0 for row 9, blank beyond
_rowkey() { if [ "$1" -lt 9 ]; then printf '%d' "$(( $1 + 1 ))"; elif [ "$1" -eq 9 ]; then printf '0'; else printf ' '; fi; }

# row <index> <plain-label> <colored-label> — shows its number; reverse-video when focused
row() {
    local k; k=$(_rowkey "$1")
    if [ "$1" -eq "$focus" ]; then
        printf '  %s%s ▸ %-40s%s\n' "$REV" "$k" "$2" "$R"
    else
        printf '   %s  %s\n' "$k" "$3"
    fi
}

# one-line explanation of the currently focused menu row
describe_main() {
    case "$1" in
        0) echo "Master switch for the whole auto-sorter (persists across reboots)." ;;
        1) echo "Run a sort pass right now." ;;
        2) echo "Dry run: show where loose files WOULD go. Moves nothing." ;;
        3) echo "Revert changes — tick individual files or whole runs; repeat to step back." ;;
        4) echo "File counts and sizes per category, plus last activity time." ;;
        5) echo "Recent moves and archives, newest first." ;;
        6) echo "Open Settings — schedule, archive age, and all the feature toggles." ;;
        7) echo "Check GitHub for a newer version and install it (verified download)." ;;
        8) echo "Detailed guide to every feature and how to use them." ;;
        9) echo "Exit this menu — the sorter keeps running in the background." ;;
    esac
}
describe_settings() {
    case "$1" in
        0)  echo "Show a banner after each sort, summarizing what moved where." ;;
        1)  echo "Tidy messy download names before filing — off by default, logged & undoable." ;;
        2)  echo "How often the backup timer runs; new files sort instantly via folder-watching." ;;
        3)  echo "How long a new download must sit still before it's sorted (0 = immediately)." ;;
        4)  echo "Files older than this move into Archive/, keeping the same folder structure." ;;
        5)  echo "Weekly heads-up if Archive holds files over a year old. Never deletes." ;;
        6)  echo "Byte-identical files go to Duplicates/ for bulk review instead of 'name (2)'." ;;
        7)  echo "Files at/above this size go to Large Files/ to handle deliberately (never archived)." ;;
        8)  echo "Rename screenshots to '2026-06-14 Screenshot.png' and file them by month." ;;
        9)  echo "Opt-in: rename PDFs from their embedded title (via Spotlight metadata)." ;;
        10) echo "Opt-in: expand downloaded .zip files into a same-named subfolder (size-guarded)." ;;
        11) echo "Opt-in: check GitHub daily on open and install verified updates automatically." ;;
        12) echo "See where every file type is filed (and your custom rules) — read-only." ;;
        13) echo "Pick categories/file types to NEVER sort (left where they are)." ;;
        14) echo "Pick categories/file types to sort EXCLUSIVELY — everything else is left alone." ;;
        15) echo "Add/remove your own 'pattern → folder' rules (they override the built-ins)." ;;
        16) echo "Return to the main menu." ;;
    esac
}

