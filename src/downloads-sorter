# do_filter <exclude|only> вЂ” interactive multi-select: tick categories and/or add
# file extensions, saved to the matching list file. Arrows move, Enter toggles/acts.
do_filter() {
    local kind="$1" file title verb sel="" line c exts
    local -a exts_arr=()          # non-category entries as an array вЂ” a value with
                                  # spaces (e.g. a custom "Word & Text" category) must
                                  # not be word-split when written back out.
    if [ "$kind" = only ]; then file="$ONLY_FILE"; title="Only sort these"; verb="sort only";
    else file="$EXCLUDE_FILE"; title="Exclude from sorting"; verb="exclude"; fi
    if [ -r "$file" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            case "$line" in ''|'#'*) continue ;; esac
            local known=0; for c in "${FILTER_CATS[@]}"; do [ "$c" = "$line" ] && { known=1; break; }; done
            if [ "$known" = 1 ]; then sel="$sel$line"$'\n'; else exts_arr+=("$line"); fi
        done < "$file"
    fi
    exts="${exts_arr[*]}"
    local n=${#FILTER_CATS[@]} nrows focus=0 key i mark input; nrows=$((n+3))
    printf '\033[?25l'
    while :; do
        exts="${exts_arr[*]}"           # display string, rebuilt from the array each frame
        printf '\033[H\033[2J'
        printf '\n  %s%s%s  %s\n' "$BLD" "$title" "$R" "${DIM}вЂ” tick categories and/or add file types to $verb${R}"
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        for i in "${!FILTER_CATS[@]}"; do
            case $'\n'"$sel" in *$'\n'"${FILTER_CATS[$i]}"$'\n'*) mark="[${GRN}вњ“${R}]" ;; *) mark="[ ]" ;; esac
            if [ "$i" -eq "$focus" ]; then printf '   %s в–ё %s %s%s\n' "$REV" "$mark" "${FILTER_CATS[$i]}" "$R"
            else printf '      %s %s\n' "$mark" "${FILTER_CATS[$i]}"; fi
        done
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        if [ "$focus" -eq "$n" ]; then       printf '   %s в–ё File types: %s%s\n' "$REV" "${exts:-(none) вЂ” Enter to add}" "$R"
        else                                 printf '      File types: %s\n' "${exts:-(none) вЂ” Enter to add}"; fi
        if [ "$focus" -eq $((n+1)) ]; then   printf '   %s в–ё Clear all%s\n' "$REV" "$R"; else printf '      Clear all\n'; fi
        if [ "$focus" -eq $((n+2)) ]; then   printf '   %s в–ё Save & back%s\n' "$REV" "$R"; else printf '      Save & back\n'; fi
        printf '\n  %sв†‘/в†“ move В· enter toggle/choose В· esc save & back%s\n' "$DIM" "$R"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + nrows - 1) % nrows )) ;;
            down|j) focus=$(( (focus + 1) % nrows )) ;;
            esc)    break ;;
            "")
                if [ "$focus" -lt "$n" ]; then
                    c="${FILTER_CATS[$focus]}"
                    case $'\n'"$sel" in
                        *$'\n'"$c"$'\n'*) sel=$(printf '%s' "$sel" | grep -vxF -- "$c"); [ -n "$sel" ] && sel="$sel"$'\n' ;;
                        *) sel="$sel$c"$'\n' ;;
                    esac
                elif [ "$focus" -eq "$n" ]; then
                    printf '\033[?25h'
                    printf '\n  Current file types: %s\n' "${exts:-(none)}"
                    printf '  Enter extensions to %s (space-separated, no dots; blank keeps current): ' "$verb"
                    IFS= read -r input; printf '\033[?25l'
                    # split the typed extensions into the array (set -f: no globbing on the split)
                    [ -n "$input" ] && { set -f; read -r -a exts_arr <<< "$(printf '%s' "$input" | tr 'A-Z' 'a-z')"; set +f; }
                elif [ "$focus" -eq $((n+1)) ]; then sel=""; exts_arr=()
                else break; fi ;;
        esac
    done
    : > "$file"
    { printf '%s' "$sel" | sed '/^$/d'; for c in "${exts_arr[@]}"; do printf '%s\n' "$c"; done; } >> "$file"
    printf '\033[?25l'
    MSG="$title: $(filter_count "$kind") item(s) saved"
}

# remove the Nth custom rule (counting only valid rule lines) from the conf
_rules_delete() {
    local rf="$1" idx="$2" i=0 line norm
    : > "$rf.tmp"
    while IFS= read -r line || [ -n "$line" ]; do
        norm="${line//в†’/->}"
        case "$line" in ''|'#'*) printf '%s\n' "$line" >> "$rf.tmp"; continue ;; esac
        case "$norm" in *'->'*) ;; *) printf '%s\n' "$line" >> "$rf.tmp"; continue ;; esac
        if [ "$i" -eq "$idx" ]; then i=$((i+1)); continue; fi
        i=$((i+1)); printf '%s\n' "$line" >> "$rf.tmp"
    done < "$rf"
    mv "$rf.tmp" "$rf"
}

# choose whether a new rule matches the filename or the download source.
# Sets RULE_BY=name|source; returns 1 if cancelled.
_rules_pick_by() {
    local f=0 k i
    local opts=("Filename вЂ” match the file's name" "Download source вЂ” match the website it came from")
    while :; do
        printf '\033[H\033[2J'
        printf '\n  %sNew rule вЂ” match by?%s\n\n' "$BLD" "$R"
        for i in 0 1; do
            if [ "$i" -eq "$f" ]; then printf '   %s в–ё %s%s\n' "$REV" "${opts[$i]}" "$R"
            else printf '     %s\n' "${opts[$i]}"; fi
        done
        printf '\n  %sв†‘/в†“ move В· enter choose В· esc cancel%s\n' "$DIM" "$R"
        k=$(read_key)
        case "$k" in
            up|k|down|j) f=$((1-f)) ;;
            esc|q)       return 1 ;;
            "")          [ "$f" -eq 1 ] && RULE_BY=source || RULE_BY=name; return 0 ;;
        esac
    done
}

# add a rule: choose match-by, enter the pattern, then pick the destination folder
_rules_add() {
    local rf="$1" pat dest cats focus=0 n i key raw RULE_BY=name
    printf '\033[?25l'
    _rules_pick_by || return
    printf '\033[?25h'
    if [ "$RULE_BY" = source ]; then
        printf '\033[H\033[2J'
        printf '\n  %sNew rule вЂ” by download source%s\n' "$BLD" "$R"
        printf '  %sFiles are tagged by macOS with the website they came from.%s\n' "$DIM" "$R"
        printf '  Match downloads from (e.g. github.com, unimelb.edu.au): '
        IFS= read -r raw; printf '\033[?25l'
        raw=$(printf '%s' "$raw" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr '[:upper:]' '[:lower:]')
        [ -z "$raw" ] && return
        case "$raw" in *'*'*) pat="source:$raw" ;; *) pat="source:*$raw*" ;; esac
    else
        printf '\033[H\033[2J'
        printf '\n  %sNew rule вЂ” by filename%s\n' "$BLD" "$R"
        printf '  Filename pattern (e.g. *statement*  or  *.dwg): '
        IFS= read -r pat; printf '\033[?25l'
        pat=$(printf '%s' "$pat" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [ -z "$pat" ] && return
    fi
    cats=( "${FILTER_CATS[@]}" "Documents/PDFs" "Documents/Word & Text" "Media/Images" "Media/Video" "Type a custom folderвЂ¦" )
    n=${#cats[@]}
    local patlabel
    case "$pat" in
        source:*) patlabel="files from ${pat#source:}"; patlabel="${patlabel//\*/}" ;;
        *)        patlabel="\"$pat\"" ;;
    esac
    while :; do
        printf '\033[H\033[2J'
        printf '\n  %sSend %s to which folder?%s\n' "$BLD" "$patlabel" "$R"
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        for i in "${!cats[@]}"; do
            if [ "$i" -eq "$focus" ]; then printf '  %s в–ё %-40s%s\n' "$REV" "${cats[$i]}" "$R"
            else printf '     %s\n' "${cats[$i]}"; fi
        done
        printf '\n  %sв†‘/в†“ move В· enter choose В· esc cancel%s\n' "$DIM" "$R"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + n - 1) % n )) ;;
            down|j) focus=$(( (focus + 1) % n )) ;;
            esc|q)  return ;;
            "")     dest="${cats[$focus]}"
                    if [ "$dest" = "Type a custom folderвЂ¦" ]; then
                        printf '\033[?25h'; printf '\n  Folder (e.g. Documents/Finance): '; IFS= read -r dest; printf '\033[?25l'
                        dest=$(printf '%s' "$dest" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                    fi
                    [ -n "$dest" ] && printf '%s -> %s\n' "$pat" "$dest" >> "$rf"
                    return ;;
        esac
    done
}

# interactive custom-rules editor (no config-file editing needed)
do_rules() {
    local rf="$HOME/.downloads-rules.conf" pats dests line p d focus=0 key i n nrows pdisp tag
    printf '\033[?25l'
    while :; do
        pats=(); dests=()
        if [ -r "$rf" ]; then
            while IFS= read -r line || [ -n "$line" ]; do
                case "$line" in ''|'#'*) continue ;; esac
                line="${line//в†’/->}"; case "$line" in *'->'*) ;; *) continue ;; esac
                p=$(printf '%s' "${line%%->*}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                d=$(printf '%s' "${line#*->}"  | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                [ -n "$p" ] && [ -n "$d" ] && { pats+=("$p"); dests+=("$d"); }
            done < "$rf"
        fi
        n=${#pats[@]}; nrows=$((n+2)); [ "$focus" -ge "$nrows" ] && focus=$((nrows-1))
        printf '\033[H\033[2J'
        printf '\n  %sCustom sorting rules%s  %sвЂ” a pattern в†’ a folder you choose%s\n' "$BLD" "$R" "$DIM" "$R"
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        [ "$n" -eq 0 ] && printf '     %s(none yet вЂ” add one below)%s\n' "$DIM" "$R"
        for i in "${!pats[@]}"; do
            pdisp="${pats[$i]}"; tag=""
            case "${pats[$i]}" in source:*) pdisp="from ${pats[$i]#source:}"; pdisp="${pdisp//\*/}"; tag=" ${DIM}В· source${R}" ;; esac
            if [ "$i" -eq "$focus" ]; then printf '  %s в–ё %-22s в†’ %-18s%s%s  enter=del\n' "$REV" "$pdisp" "${dests[$i]}" "$R" "$tag"
            else printf '     %-22s в†’ %s%s\n' "$pdisp" "${dests[$i]}" "$tag"; fi
        done
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        if [ "$focus" -eq "$n" ]; then printf '  %s в–ё + Add a rule%s\n' "$REV" "$R"; else printf '     + Add a rule\n'; fi
        if [ "$focus" -eq $((n+1)) ]; then printf '  %s в–ё в†ђ Back%s\n' "$REV" "$R"; else printf '     в†ђ Back\n'; fi
        printf '\n  %sв†‘/в†“ move В· enter delete/add В· esc back%s\n' "$DIM" "$R"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + nrows - 1) % nrows )) ;;
            down|j) focus=$(( (focus + 1) % nrows )) ;;
            esc|q)  break ;;
            "")     if   [ "$focus" -lt "$n" ]; then _rules_delete "$rf" "$focus"; focus=0
                    elif [ "$focus" -eq "$n" ]; then _rules_add "$rf"; focus=0
                    else break; fi ;;
        esac
    done
    printf '\033[?25l'; MSG="Custom sorting rules updated"
}

# --- Folder colours (Finder colour tags on category folders) -------------
COLOR_NAMES=(None Red Orange Yellow Green Blue Purple Gray)
# a coloured в—Џ swatch (в—‹ for None) for the picker
_color_swatch() {
    case "$1" in
        Red)       printf '\033[31mв—Џ\033[0m' ;;
        Orange)    printf '\033[38;5;208mв—Џ\033[0m' ;;
        Yellow)    printf '\033[33mв—Џ\033[0m' ;;
        Green)     printf '\033[32mв—Џ\033[0m' ;;
        Blue)      printf '\033[34mв—Џ\033[0m' ;;
        Purple)    printf '\033[35mв—Џ\033[0m' ;;
        Gray|Grey) printf '\033[90mв—Џ\033[0m' ;;
        *)         printf '\033[2mв—‹\033[0m' ;;
    esac
}
_colors_get() {  # <category> -> saved colour name, or empty
    [ -r "$COLORS_FILE" ] || return 0
    awk -F'|' -v c="$1" '$1==c{print $2; exit}' "$COLORS_FILE"
}
_colors_set() {  # <category> <colour|None> вЂ” rewrite the mapping for that category
    local cat="$1" col="$2" tmp; tmp=$(mktemp)
    [ -r "$COLORS_FILE" ] && awk -F'|' -v c="$cat" '$1!=c' "$COLORS_FILE" > "$tmp"
    [ "$col" != None ] && [ -n "$col" ] && printf '%s|%s\n' "$cat" "$col" >> "$tmp"
    mv "$tmp" "$COLORS_FILE"
}
# apply a colour to a folder NOW (reuses the sorter's tagger so logic stays in one place)
_colors_apply_now() {  # <category> <colour>
    # shellcheck source=/dev/null
    ( source "$SORTER" >/dev/null 2>&1 && set_folder_color "$DIR/$1" "$2" ) 2>/dev/null
}
# colour picker for one category
_colors_pick() {  # <category>
    local cat="$1" cur f=0 i k sw curmark
    cur=$(_colors_get "$cat"); [ -z "$cur" ] && cur=None
    for i in "${!COLOR_NAMES[@]}"; do [ "${COLOR_NAMES[$i]}" = "$cur" ] && f="$i"; done
    while :; do
        printf '\033[H\033[2J'
        printf '\n  %sColour for "%s"%s\n\n' "$BLD" "$cat" "$R"
        for i in "${!COLOR_NAMES[@]}"; do
            sw=$(_color_swatch "${COLOR_NAMES[$i]}")
            curmark=""; [ "${COLOR_NAMES[$i]}" = "$cur" ] && curmark=" ${GRN}В· current${R}"
            if [ "$i" -eq "$f" ]; then printf '   %s в–ё %s %-8s%s%s\n' "$REV" "$sw" "${COLOR_NAMES[$i]}" "$R" "$curmark"
            else printf '     %s %s%s\n' "$sw" "${COLOR_NAMES[$i]}" "$curmark"; fi
        done
        printf '\n  %sв†‘/в†“ move В· enter set В· esc cancel%s\n' "$DIM" "$R"
        k=$(read_key)
        case "$k" in
            up|k)   f=$(( (f + ${#COLOR_NAMES[@]} - 1) % ${#COLOR_NAMES[@]} )) ;;
            down|j) f=$(( (f + 1) % ${#COLOR_NAMES[@]} )) ;;
            esc|q)  return ;;
            "")     _colors_set "$cat" "${COLOR_NAMES[$f]}"; _colors_apply_now "$cat" "${COLOR_NAMES[$f]}"
                    MSG="$cat в†’ ${COLOR_NAMES[$f]}"; return ;;
        esac
    done
}
# Folder-colours editor: a list of category folders, each with its colour
do_colors() {
    local cats focus=0 i n key cur sw nrows
    cats=( "${FILTER_CATS[@]}" "Archive" "Duplicates" "Large Files" )
    n=${#cats[@]}; nrows=$((n+1))
    printf '\033[?25l'
    while :; do
        [ "$focus" -ge "$nrows" ] && focus=$((nrows-1))
        printf '\033[H\033[2J'
        printf '\n  %sFolder colours%s  %sвЂ” Finder colour tags on category folders (auto-applied)%s\n' "$BLD" "$R" "$DIM" "$R"
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        for i in "${!cats[@]}"; do
            cur=$(_colors_get "${cats[$i]}"); sw=$(_color_swatch "${cur:-None}")
            if [ "$i" -eq "$focus" ]; then printf '  %s в–ё %-24s %s %s%s\n' "$REV" "${cats[$i]}" "$sw" "${cur:-вЂ”}" "$R"
            else printf '     %-24s %s %s\n' "${cats[$i]}" "$sw" "${cur:-вЂ”}"; fi
        done
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        if [ "$focus" -eq "$n" ]; then printf '  %s в–ё в†ђ Back%s\n' "$REV" "$R"; else printf '     в†ђ Back\n'; fi
        printf '\n  %sв†‘/в†“ move В· enter pick colour В· esc back%s\n' "$DIM" "$R"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + nrows - 1) % nrows )) ;;
            down|j) focus=$(( (focus + 1) % nrows )) ;;
            esc|q)  break ;;
            "")     if [ "$focus" -lt "$n" ]; then _colors_pick "${cats[$focus]}"; printf '\033[?25l'; else break; fi ;;
        esac
    done
    printf '\033[?25l'; MSG="Folder colours updated"
}

# --- Empty-folder cleanup (optional, removes OTHER empty folders too) -------
# simple add/remove editor for a folder-name list file (blacklist / whitelist)
_prune_list_edit() {
    local file="$1" title="$2" hint="$3" items focus=0 key i n nrows input frame
    printf '\033[?25l'
    while :; do
        items=(); while IFS= read -r i; do items+=("$i"); done < <(grep -vE '^[[:space:]]*(#|$)' "$file" 2>/dev/null)
        n=${#items[@]}; nrows=$((n+2)); [ "$focus" -ge "$nrows" ] && focus=$((nrows-1))
        frame=$(
            printf '\n  %s%s%s\n' "$BLD" "$title" "$R"
            printf '  %s%s%s\n' "$DIM" "$hint" "$R"
            printf '  %sв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ%s\n' "$DIM" "$R"
            [ "$n" -eq 0 ] && printf '     %s(none yet)%s\n' "$DIM" "$R"
            for i in "${!items[@]}"; do
                if [ "$i" -eq "$focus" ]; then printf '  %s в–ё %-32s%s  enter=remove\n' "$REV" "${items[$i]}" "$R"
                else printf '     %s\n' "${items[$i]}"; fi
            done
            printf '  %sв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ%s\n' "$DIM" "$R"
            if [ "$focus" -eq "$n" ]; then printf '  %s в–ё + Add a folder name%s\n' "$REV" "$R"; else printf '     + Add a folder name\n'; fi
            if [ "$focus" -eq $((n+1)) ]; then printf '  %s в–ё в†ђ Back%s\n' "$REV" "$R"; else printf '     в†ђ Back\n'; fi
            printf '\n  %sв†‘/в†“ move В· enter remove/add В· esc back%s\n' "$DIM" "$R"
        )
        _paint "$frame"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + nrows - 1) % nrows )) ;;
            down|j) focus=$(( (focus + 1) % nrows )) ;;
            esc|q)  break ;;
            "")     if [ "$focus" -lt "$n" ]; then
                        grep -vxF -- "${items[$focus]}" "$file" 2>/dev/null > "$file.tmp"; mv "$file.tmp" "$file" 2>/dev/null; focus=0
                    elif [ "$focus" -eq "$n" ]; then
                        printf '\033[?25h'; printf '\n  Folder name (or relative path, e.g. Projects/Active): '; IFS= read -r input; printf '\033[?25l'
                        input=$(printf '%s' "$input" | sed 's#^[[:space:]/]*##; s#[[:space:]/]*$##')
                        [ -n "$input" ] && printf '%s\n' "$input" >> "$file"; focus=0
                    else break; fi ;;
        esac
    done
    printf '\033[?25l'
}
# pick the 3-way cleanup scope
_prune_scope_pick() {
    local cur f=0 i k
    local names=(managed user all)
    local labels=("Category folders only (this app's)" "Also folders you created" "Every empty folder")
    cur=$(get_prune_scope); for i in 0 1 2; do [ "${names[$i]}" = "$cur" ] && f="$i"; done
    while :; do
        printf '\033[H'
        printf '\n  %sEmpty-folder cleanup вЂ” scope%s\n\n' "$BLD" "$R"
        for i in 0 1 2; do
            if [ "$i" -eq "$f" ]; then printf '   %s в–ё %-34s%s%s\n\033[K' "$REV" "${labels[$i]}" "$R" "$([ "${names[$i]}" = "$cur" ] && printf ' %sВ· current%s' "$GRN" "$R")"
            else printf '     %-34s%s\n\033[K' "${labels[$i]}" "$([ "${names[$i]}" = "$cur" ] && printf ' %sВ· current%s' "$GRN" "$R")"; fi
        done
        printf '\n  %sCategory folders are always tidied. Hidden + Syncthing folders are always safe.%s\n\033[K' "$DIM" "$R"
        printf '  %sв†‘/в†“ move В· enter set В· esc cancel%s\n\033[K\033[J' "$DIM" "$R"
        k=$(read_key)
        case "$k" in
            up|k)   f=$(( (f+2)%3 )) ;;
            down|j) f=$(( (f+1)%3 )) ;;
            esc|q)  return ;;
            "")     set_prune_scope "${names[$f]}"; MSG="Cleanup scope -> ${labels[$f]}"; return ;;
        esac
    done
}
# Empty-folder cleanup submenu: scope + blacklist + whitelist
do_emptyfolders() {
    local focus=0 key frame desc kc oc sc sclabel
    printf '\033[?25l'
    while :; do
        kc=$(prunekeep_count); oc=$(pruneonly_count); sc=$(get_prune_scope)
        case "$sc" in managed) sclabel="category only" ;; user) sclabel="+ your folders" ;; all) sclabel="every folder" ;; esac
        case "$focus" in
            0) desc="How far cleanup reaches: this app's category folders only, also your folders, or every folder." ;;
            1) desc="Folders to NEVER delete (name or relative path). Hidden + Syncthing folders are always safe." ;;
            2) desc="If set, ONLY delete empty folders matching these вЂ” everything else is kept." ;;
            *) desc="Return to Settings." ;;
        esac
        frame=$(
            printf '\n  %sEmpty-folder cleanup%s\n' "$BLD" "$R"
            printf '  %sв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ%s\n' "$DIM" "$R"
            if [ "$focus" -eq 0 ]; then printf '  %s в–ё %-28s%s %s%s%s\n' "$REV" "Scope" "$R" "$GRN" "$sclabel" "$R"
            else printf '     %-28s %s%s%s\n' "Scope" "$GRN" "$sclabel" "$R"; fi
            if [ "$focus" -eq 1 ]; then printf '  %s в–ё %-28s%s %s(%s)%s\n' "$REV" "Never delete (blacklist) в–ё" "$R" "$DIM" "$kc" "$R"
            else printf '     %-28s %s(%s)%s\n' "Never delete (blacklist) в–ё" "$DIM" "$kc" "$R"; fi
            if [ "$focus" -eq 2 ]; then printf '  %s в–ё %-28s%s %s(%s)%s\n' "$REV" "Only these (whitelist) в–ё" "$R" "$DIM" "$oc" "$R"
            else printf '     %-28s %s(%s)%s\n' "Only these (whitelist) в–ё" "$DIM" "$oc" "$R"; fi
            printf '  %sв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ%s\n' "$DIM" "$R"
            if [ "$focus" -eq 3 ]; then printf '  %s в–ё в†ђ Back%s\n' "$REV" "$R"; else printf '     в†ђ Back\n'; fi
            printf '\n  %sвћњ %s%s\n' "$DIM" "$desc" "$R"
            printf '  %s\n' "${GRN}${MSG}${R}"
            printf '  %sв†‘/в†“ move В· enter select В· esc back%s\n' "$DIM" "$R"
        )
        _paint "$frame"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + 3) % 4 )) ;;
            down|j) focus=$(( (focus + 1) % 4 )) ;;
            esc|q)  break ;;
            "")     case "$focus" in
                        0) _prune_scope_pick; printf '\033[?25l' ;;
                        1) _prune_list_edit "$PRUNE_KEEP" "Never delete (blacklist)" "Empty folders matching these are always kept." ; MSG="Blacklist updated" ;;
                        2) _prune_list_edit "$PRUNE_ONLY" "Only delete these (whitelist)" "If non-empty, only empty folders matching these are removed." ; MSG="Whitelist updated" ;;
                        3) break ;;
                    esac ;;
        esac
    done
    printf '\033[?25l'; MSG="Empty-folder cleanup updated"
}

activate() {
    if [ "$SCREEN" = settings ]; then
        case "$focus" in
            0)  do_notifications ;;
            1)  toggle_cleannames ;;
            2)  pick_interval ;;
            3)  form_grace ;;
            4)  prompt_archivedays ;;
            5)  toggle_aging ;;
            6)  toggle_duplicates ;;
            7)  pick_largefile ;;
            8)  toggle_screenshotdate ;;
            9)  toggle_metanames ;;
            10) toggle_autounzip ;;
            11) toggle_autoupdate ;;
            12) prompt_recent ;;
            13) toggle_digest ;;
            14) do_categories ;;
            15) do_filter exclude ;;
            16) do_filter only ;;
            17) do_rules ;;
            18) do_colors ;;
            19) do_emptyfolders ;;
            20) SCREEN=main; focus=6 ;;
        esac
    else
        case "$focus" in
            0) toggle_sorter ;;
            1) do_run ;;
            2) do_preview ;;
            3) do_undo ;;
            4) do_stats ;;
            5) do_log ;;
            6) SCREEN=settings; focus=0 ;;
            7) do_update ;;
            8) do_help ;;
            9) QUIT=1 ;;
        esac
    fi
}

ui_main() {
    local QUIT=0 focus=0 MSG="" key SCREEN=main NROWS idx
    maybe_autoupdate      # only if Auto-update is ON; checks at most once a day
    # alternate screen: menu doesn't eat scrollback; prior content restored on exit
    [ -t 1 ] && printf '\033[?1049h'
    printf '\033[?25l'
    trap 'printf "\033[?1049l\033[?25h\033[0m"' EXIT
    while [ "$QUIT" -eq 0 ]; do
        [ "$SCREEN" = settings ] && NROWS=21 || NROWS=10
        draw
        MSG=""
        key=$(read_key) || break
        case "$key" in
            up|k)   focus=$(( (focus + NROWS - 1) % NROWS )); continue ;;
            down|j) focus=$(( (focus + 1) % NROWS )); continue ;;
            "")     activate; continue ;;
            [0-9])  # number shortcut: main menu only (Settings has too many rows
                    # for 1-9,0 to be meaningful, so it uses arrows/enter only)
                    if [ "$SCREEN" != settings ]; then
                        if [ "$key" = 0 ]; then idx=9; else idx=$((key - 1)); fi
                        if [ "$idx" -lt "$NROWS" ]; then focus=$idx; activate; fi
                    fi
                    continue ;;
        esac
        # only navigation keys are screen-specific now
        if [ "$SCREEN" = settings ]; then
            case "$key" in esc) SCREEN=main; focus=6 ;; q) QUIT=1 ;; esac
        else
            case "$key" in q|esc) QUIT=1 ;; esac
        fi
    done
    printf '\033[?1049l\033[?25h'
    show_status
}

# ---------- dispatch ----------

case "$1" in
    on)
        sorter_on
        echo "Downloads sorter: ON" ;;
    off)
        sorter_off
        echo "Downloads sorter: OFF (stays off until you run: dsort on)" ;;
    run)
        launchctl kickstart "$TARGET" && echo "Sort pass triggered." ;;
    log)
        tail -n "${2:-15}" "$LOG" ;;
    notify)
        case "$2" in
            on)  rm -f "$NONOTIFY_FLAG"; echo "Notifications: ON" ;;
            off) touch "$NONOTIFY_FLAG"; echo "Notifications: OFF" ;;
            *)   notify_is_on && echo "Notifications: ON" || echo "Notifications: OFF" ;;
        esac ;;
    detect|detectnotify)
        case "$2" in
            on)  touch "$DETECT_FLAG"; echo "Detected heads-up: ON" ;;
            off) rm -f "$DETECT_FLAG"; echo "Detected heads-up: OFF" ;;
            *)   detect_is_on && echo "Detected heads-up: ON" || echo "Detected heads-up: OFF (opt-in)" ;;
        esac ;;
    cleannames)
        case "$2" in
            on)  touch "$CLEANFLAG"; echo "Filename cleanup: ON" ;;
            off) rm -f "$CLEANFLAG"; echo "Filename cleanup: OFF" ;;
            *)   clean_is_on && echo "Filename cleanup: ON" || echo "Filename cleanup: OFF" ;;
        esac ;;
    aging)
        case "$2" in
            on)  rm -f "$AGING_FLAG"; echo "Aging nudge: ON" ;;
            off) touch "$AGING_FLAG"; echo "Aging nudge: OFF" ;;
            *)   aging_is_on && echo "Aging nudge: ON" || echo "Aging nudge: OFF" ;;
        esac ;;
    digest)
        case "$2" in
            on)  touch "$DIGEST_FLAG"; echo "Weekly digest: ON" ;;
            off) rm -f "$DIGEST_FLAG"; echo "Weekly digest: OFF" ;;
            *)   digest_is_on && echo "Weekly digest: ON" || echo "Weekly digest: OFF (opt-in)" ;;
        esac ;;
    duplicates)
        case "$2" in
            on)  rm -f "$DEDUP_FLAG"; echo "Duplicate routing: ON" ;;
            off) touch "$DEDUP_FLAG"; echo "Duplicate routing: OFF" ;;
            *)   dedup_is_on && echo "Duplicate routing: ON" || echo "Duplicate routing: OFF" ;;
