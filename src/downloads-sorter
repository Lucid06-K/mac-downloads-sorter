# true if version $1 is strictly newer than $2 (dotted semver, via sort -V)
ver_gt() { [ "$1" != "$2" ] && [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)" = "$1" ]; }

# Returns 0 if updated or already current, 1 on any failure (leaves files intact).
CURL_SAFE='curl -fsSL --proto =https --proto-redir =https --max-redirs 3'
run_update() {
    command -v curl >/dev/null 2>&1 || { echo "curl is required for updates."; return 1; }
    command -v openssl >/dev/null 2>&1 || { echo "openssl is required to verify updates."; return 1; }
    local tmp newver cur_label instver
    echo "Checking github.com/Lucid06-K/mac-downloads-sorter вЂ¦"
    newver=$($CURL_SAFE "$REPO_RAW/VERSION" 2>/dev/null | tr -dc '0-9.')
    [ -n "$newver" ] || { echo "Couldn't reach the update server (check your connection)."; return 1; }
    echo "  installed: v$VERSION    latest: v$newver"
    [ "$newver" = "$VERSION" ] && { echo "You're already up to date."; return 0; }
    # never go backwards: a stale CDN cache or a rollback must not downgrade you
    if ! ver_gt "$newver" "$VERSION"; then
        echo "Your version (v$VERSION) is newer than the server's (v$newver) вЂ” keeping yours."
        echo "(If the server was just updated, its CDN can lag a few minutes; try again shortly.)"
        return 0
    fi
    tmp=$(mktemp -d)
    $CURL_SAFE "$REPO_RAW/src/organize_downloads.sh" -o "$tmp/organize_downloads.sh" 2>/dev/null
    $CURL_SAFE "$REPO_RAW/src/downloads-sorter"       -o "$tmp/downloads-sorter"       2>/dev/null
    $CURL_SAFE "$REPO_RAW/SHA256SUMS"                 -o "$tmp/SHA256SUMS"             2>/dev/null
    $CURL_SAFE "$REPO_RAW/SHA256SUMS.sig"             -o "$tmp/SHA256SUMS.sig"         2>/dev/null
    if [ ! -s "$tmp/organize_downloads.sh" ] || [ ! -s "$tmp/downloads-sorter" ]; then
        echo "Download failed вЂ” nothing changed."; rm -rf "$tmp"; return 1; fi
    if [ ! -s "$tmp/SHA256SUMS" ]; then
        echo "вњ— Couldn't fetch checksums вЂ” refusing to install unverified code."
        rm -rf "$tmp"; return 1; fi
    # authenticity: the manifest must carry a valid signature from the project's
    # offline key. This is what makes a repo/CDN/TLS compromise insufficient.
    if [ ! -s "$tmp/SHA256SUMS.sig" ]; then
        echo "вњ— Update is not signed вЂ” refusing to install. Aborting."
        rm -rf "$tmp"; return 1; fi
    printf '%s\n' "$UPDATE_PUBKEY" > "$tmp/update.pub"
    if ! openssl dgst -sha256 -verify "$tmp/update.pub" -signature "$tmp/SHA256SUMS.sig" "$tmp/SHA256SUMS" >/dev/null 2>&1; then
        echo "вњ— Signature check FAILED вЂ” manifest is not signed by the project key. Aborting."
        rm -rf "$tmp"; return 1
    fi
    echo "  вњ“ signature verified"
    # integrity: the downloaded bytes must match the (now-trusted) checksums
    if ! ( cd "$tmp" && shasum -a 256 -c SHA256SUMS >/dev/null 2>&1 ); then
        echo "вњ— Integrity check FAILED вЂ” download didn't match published checksums. Aborting."
        rm -rf "$tmp"; return 1
    fi
    echo "  вњ“ checksums verified"
    # corruption guard (after integrity, before we touch anything)
    if ! bash -n "$tmp/organize_downloads.sh" || ! bash -n "$tmp/downloads-sorter"; then
        echo "вњ— Downloaded files failed a syntax check вЂ” nothing changed."; rm -rf "$tmp"; return 1; fi
    # keep this machine's launch-agent label (done after verification, so it can't affect the hash)
    cur_label=$(grep -m1 '^LABEL=' "$SELF" 2>/dev/null)
    [ -n "$cur_label" ] && sed -i '' "s|^LABEL=.*|$cur_label|" "$tmp/downloads-sorter"
    # authoritative new version = what the downloaded script actually reports.
    # The standalone VERSION pointer file is NOT in SHA256SUMS, but the script
    # embeds its own VERSION and the script IS checksum-verified вЂ” so trust the
    # embedded value and cross-check the pointer against it. A mismatch means the
    # pointer was tampered with or the CDN is mid-propagation; either way we keep
    # the verified value and never install on the strength of the pointer alone.
    instver=$(grep -m1 '^VERSION=' "$tmp/downloads-sorter" | cut -d'"' -f2); instver="${instver:-$newver}"
    if [ -n "$newver" ] && [ "$newver" != "$instver" ]; then
        echo "  note: server version pointer (v$newver) в‰  verified package (v$instver); trusting the verified package."
    fi
    cp "$SORTER" "$SORTER.bak" 2>/dev/null; cp "$SELF" "$SELF.bak" 2>/dev/null
    install -m 0755 "$tmp/organize_downloads.sh" "$SORTER"
    install -m 0755 "$tmp/downloads-sorter" "$SELF"
    rm -rf "$tmp"
    echo "Updated v$VERSION в†’ v$instver вњ“   (previous versions saved as *.bak)"
    echo "Re-open the menu (or your shell) to use the new version."
}

# called when the menu opens: if auto-update is ON and a day has passed, check
# and (if newer) install via the same verified path as a manual update.
maybe_autoupdate() {
    autoupdate_on || return 0
    command -v curl >/dev/null 2>&1 || return 0
    local last now newver
    if [ -f "$UPDATE_STAMP" ]; then
        last=$(stat -f %m "$UPDATE_STAMP" 2>/dev/null || echo 0); now=$(date +%s)
        [ $((now - last)) -lt 86400 ] && return 0      # checked within the last day
    fi
    touch "$UPDATE_STAMP"
    newver=$($CURL_SAFE "$REPO_RAW/VERSION" 2>/dev/null | tr -dc '0-9.')
    [ -n "$newver" ] && ver_gt "$newver" "$VERSION" || return 0
    echo "Auto-update: a newer version (v$newver) is available вЂ” installingвЂ¦"
    run_update
    printf '\n  press any key to open the menuвЂ¦ '; IFS= read -r -s -n 1 _ 2>/dev/null
}

