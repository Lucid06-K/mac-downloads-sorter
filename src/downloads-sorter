# grace period as a Days/Hours/Minutes/Seconds form вЂ” type a number in each
# field (they add up). e.g. Minutes=1, Seconds=30 -> 1m 30s (90s). Max 31d.
form_grace() {
    local cur focus=0 k i tot nv
    local labels=(Days Hours Minutes Seconds) maxes=(31 23 59 59)
    cur=$(get_grace); cur=$((10#${cur:-0}))      # base-10 (avoid octal on leading 0)
    local vals=( $((cur/86400)) $(((cur%86400)/3600)) $(((cur%3600)/60)) $((cur%60)) )
    while :; do
        tot=$(( vals[0]*86400 + vals[1]*3600 + vals[2]*60 + vals[3] ))
        printf '\033[H\033[2J'
        printf '\n  %sGrace period%s  %sвЂ” how long a download settles before sorting%s\n' "$BLD" "$R" "$DIM" "$R"
        printf '  %sType a number in each field; they add up. Default %ss.%s\n' "$DIM" "$RECOMMENDED_GRACE" "$R"
        printf '  %s0 = immediate (sorts on sight) вЂ” also turns off the "detected" heads-up.%s\n\n' "$DIM" "$R"
        for i in 0 1 2 3; do
            if [ "$i" -eq "$focus" ]; then printf '   %s в–ё %-8s [ %2s ] %s %s(0вЂ“%s)%s\n' "$REV" "${labels[$i]}" "${vals[$i]}" "$R" "$DIM" "${maxes[$i]}" "$R"
            else printf '     %-8s [ %2s ]   %s(0вЂ“%s)%s\n' "${labels[$i]}" "${vals[$i]}" "$DIM" "${maxes[$i]}" "$R"; fi
        done
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        printf '   %sTotal:%s %s\n' "$BLD" "$R" "$(fmt_grace "$tot")"
        printf '  %s\n' "${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${R}"
        if [ "$focus" -eq 4 ]; then printf '  %s в–ё Save%s\n' "$REV" "$R"; else printf '     Save\n'; fi
        printf '\n  %sв†‘/в†“ field В· type digits В· вЊ« delete В· enter save В· esc cancel%s\n' "$DIM" "$R"
        k=$(read_key)
        case "$k" in
            up|k)   focus=$(( (focus + 4) % 5 )) ;;
            down|j) focus=$(( (focus + 1) % 5 )) ;;
            esc|q)  MSG="Grace period unchanged"; return ;;
            [0-9])  if [ "$focus" -lt 4 ]; then
                        nv=$(( vals[focus]*10 + k ))
                        [ "$nv" -gt "${maxes[$focus]}" ] && nv="$k"
                        vals[$focus]=$nv
                    fi ;;
            $'\177'|$'\b') [ "$focus" -lt 4 ] && vals[$focus]=$(( vals[focus] / 10 )) ;;
            "")     if set_grace "$tot"; then
                        if [ "$tot" -eq 0 ] && detect_is_on; then rm -f "$DETECT_FLAG"; MSG="Grace в†’ immediate В· detected heads-up turned off"
                        else MSG="Grace period в†’ $(fmt_grace "$tot")"; fi
                    else MSG="Could not set grace period"; fi
                    return ;;
        esac
    done
}

