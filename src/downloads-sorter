get_largefile() {
    local v=""
    [ -r "$LFFILE" ] && v=$(tr -dc '0-9' < "$LFFILE" 2>/dev/null)
    [ -n "$v" ] && echo "$v" || echo "$RECOMMENDED_LARGEFILE_GB"
}
set_largefile() { case "$1" in *[!0-9]*|"") return 1 ;; esac; printf '%s\n' "$((10#$1))" > "$LFFILE"; }   # 10# avoids octal on a leading 0 (e.g. 09)

sorter_on()  { launchctl enable "$TARGET"; launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null; }
sorter_off() { launchctl bootout "$TARGET" 2>/dev/null; launchctl disable "$TARGET"; }

# read/format/set the launchd StartInterval (the safety-net auto-run cadence)
get_interval() {
    local v=""
    [ -r "$PLIST" ] && v=$(/usr/libexec/PlistBuddy -c "Print :StartInterval" "$PLIST" 2>/dev/null)
    case "$v" in ""|*[!0-9]*) echo "" ;; *) echo "$v" ;; esac   # only ever a clean integer (or empty)
}
fmt_interval() {
    local s="$1"
    if   [ -z "$s" ] || [ "$s" -le 0 ] 2>/dev/null;            then echo "off"
    elif [ "$s" -ge 86400 ] && [ $((s % 86400)) -eq 0 ]; then echo "$((s/86400))d"
    elif [ "$s" -ge 3600 ]  && [ $((s % 3600))  -eq 0 ]; then echo "$((s/3600))h"
    elif [ "$s" -ge 60 ]    && [ $((s % 60))    -eq 0 ]; then echo "$((s/60))m"
    else echo "${s}s"; fi
}
set_interval() {
    local secs="$1"
    case "$secs" in ""|*[!0-9]*) return 1 ;; esac     # digits only
    [ "$secs" -lt 60 ] && return 1                    # launchd throttles below this anyway
    /usr/libexec/PlistBuddy -c "Set :StartInterval $secs" "$PLIST" 2>/dev/null \
        || /usr/libexec/PlistBuddy -c "Add :StartInterval integer $secs" "$PLIST" 2>/dev/null || return 1
    # reload so launchd picks up the change вЂ” but only if it's currently running,
    # so we never silently turn a disabled sorter back on
    if is_loaded; then
        launchctl bootout "$TARGET" 2>/dev/null
        launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null
    fi
}

# archive age (in days); stored in AGEFILE, default RECOMMENDED_ARCHIVE_DAYS
get_archivedays() {
    local v=""
    [ -r "$AGEFILE" ] && v=$(tr -dc '0-9' < "$AGEFILE" 2>/dev/null)
    [ -n "$v" ] && echo "$v" || echo "$RECOMMENDED_ARCHIVE_DAYS"
}
set_archivedays() {
    local d="$1"
    case "$d" in ""|*[!0-9]*) return 1 ;; esac
    [ "$d" -lt 1 ] && return 1
    printf '%s\n' "$d" > "$AGEFILE"
}

# grace period (in seconds) before a freshly-modified file is sorted; stored in
# GRACEFILE, default RECOMMENDED_GRACE. 0 = sort immediately. Capped at 1 day.
get_grace() {
    local v=""
    [ -r "$GRACEFILE" ] && v=$(tr -dc '0-9' < "$GRACEFILE" 2>/dev/null)
    [ -n "$v" ] && echo "$v" || echo "$RECOMMENDED_GRACE"
}
set_grace() {
    local s="$1"
    case "$s" in ""|*[!0-9]*) return 1 ;; esac
    s=$((10#$s))                             # normalise (avoid octal on leading 0)
    [ "$s" -gt 2764799 ] && return 1         # max 31d 23h 59m 59s
    printf '%s\n' "$s" > "$GRACEFILE"
}

# how many recent moves to list under the main menu; stored in RECENTFILE,
# default RECOMMENDED_RECENT, 0 = hide the list, capped at 10 (menu height).
get_recent_count() {
    local v=""
    [ -r "$RECENTFILE" ] && v=$(tr -dc '0-9' < "$RECENTFILE" 2>/dev/null)
    [ -n "$v" ] && echo "$v" || echo "$RECOMMENDED_RECENT"
}
set_recent_count() {
    local n="$1"
    case "$n" in ""|*[!0-9]*) return 1 ;; esac
    [ "$n" -gt 10 ] && return 1
    printf '%s\n' "$n" > "$RECENTFILE"
}
# friendly label with all nonzero parts:
# "0s (immediate)", "30s", "1m 30s", "2h 5m", "31d 23h 59m 59s"
fmt_grace() {
    local s="$1" out="" dd hh mm ss
    case "$s" in ''|*[!0-9]*) echo "$s"; return ;; esac
    [ "$s" -eq 0 ] && { echo "0s (immediate)"; return; }
    dd=$((s/86400)); hh=$(((s%86400)/3600)); mm=$(((s%3600)/60)); ss=$((s%60))
    [ "$dd" -gt 0 ] && out="$out${dd}d "
    [ "$hh" -gt 0 ] && out="$out${hh}h "
    [ "$mm" -gt 0 ] && out="$out${mm}m "
    [ "$ss" -gt 0 ] && out="$out${ss}s "
    echo "${out% }"
}

# --- undo history (a stack of moves) ------------------------------------
# Backfill the undo stack from the activity log so sortings that predate the
# history file вЂ” or any move only the log recorded вЂ” become revertable. We
# reconstruct old<TAB>new from `moved:`/`duplicate:` lines, pairing a same-second
# `renamed:` line so dated screenshots / cleaned names restore to their original
# name. Conservative and idempotent by design:
#   вЂў a record is imported only if its destination file is on disk right now
#   вЂў a destination already in the history is never added twice (keyed by dest)
#   вЂў `archived:` lines are skipped вЂ” the log doesn't record the origin folder
#   вЂў collision-suffixed names (" (2)") aren't in the log, so those are left be
# Worst case a reconstructed record matches nothing and is skipped at revert
# time: _undo_one only ever moves a file back, it never deletes or clobbers.
_undo_import_log() {
    [ -r "$LOG" ] || return 0
    local dir="$HOME/Downloads" seen merged line ts rest verb payload base reldir
    local oldbase newpath oldpath epoch prev_ts="" prev_old="" prev_new=""
    seen=$(mktemp); merged=$(mktemp)
    [ -r "$HISTORY_FILE" ] && cut -f3 "$HISTORY_FILE" 2>/dev/null > "$seen"
    while IFS= read -r line || [ -n "$line" ]; do
        [ ${#line} -gt 20 ] || continue
        ts="${line:0:19}"; rest="${line:20}"
        verb="${rest%%:*}"; payload="${rest#*: }"
        case "$verb" in
            renamed) prev_ts="$ts"; prev_new="${payload##* -> }"; prev_old="${payload% -> *}"; continue ;;
            moved|duplicate) : ;;
            *) prev_ts=""; continue ;;
        esac
        base="${payload% -> *}"; reldir="${payload##* -> }"; reldir="${reldir%/}"
        [ -n "$base" ] && [ -n "$reldir" ] || { prev_ts=""; continue; }
        newpath="$dir/$reldir/$base"
        if [ "$prev_ts" = "$ts" ] && [ "$prev_new" = "$base" ]; then oldbase="$prev_old"; else oldbase="$base"; fi
        oldpath="$dir/$oldbase"; prev_ts=""
        [ -e "$newpath" ] || continue
        grep -qxF -- "$newpath" "$seen" 2>/dev/null && continue
        epoch=$(date -j -f "%Y-%m-%d %H:%M:%S" "$ts" +%s 2>/dev/null)
        case "$epoch" in ''|*[!0-9]*) continue ;; esac
        printf '%s\t%s\t%s\n' "$epoch" "$oldpath" "$newpath" >> "$merged"
        printf '%s\n' "$newpath" >> "$seen"
    done < "$LOG"
    if [ -s "$merged" ]; then
        cat "$merged" >> "$HISTORY_FILE"
        sort -t$'\t' -k1,1n "$HISTORY_FILE" -o "$HISTORY_FILE" 2>/dev/null
        if [ "$(wc -l < "$HISTORY_FILE" 2>/dev/null || echo 0)" -gt 3000 ]; then
            tail -n 2000 "$HISTORY_FILE" > "$HISTORY_FILE.tmp" 2>/dev/null && mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"
        fi
    fi
    rm -f "$seen" "$merged"
}
# Prepare the stack once per process: migrate the legacy single-run file (older
# installs) and backfill from the log. Guarded so repeated _undo_load calls
# (e.g. after each revert) don't re-scan the log.
_undo_prepare() {
    [ "${_undo_prepared:-0}" = 1 ] && return 0
    _undo_prepared=1
    if [ -s "$UNDO_FILE" ] && [ ! -e "$HISTORY_FILE" ]; then
        local l; while IFS= read -r l; do [ -n "$l" ] && printf '0\t%s\n' "$l" >> "$HISTORY_FILE"; done < "$UNDO_FILE"
        rm -f "$UNDO_FILE"
    fi
    _undo_import_log
}
# load history newest-first into U_STAMP / U_OLD / U_NEW
_undo_load() {
    _undo_prepare
    U_STAMP=(); U_OLD=(); U_NEW=()
    [ -r "$HISTORY_FILE" ] || return 0
    local s o n
    while IFS=$'\t' read -r s o n; do
        [ -n "$o" ] && [ -n "$n" ] || continue
        U_STAMP+=("$s"); U_OLD+=("$o"); U_NEW+=("$n")
    done < <(tail -r "$HISTORY_FILE" 2>/dev/null)
}
# move one file back (new -> old). never deletes; never clobbers an occupied origin
_undo_one() {
    local new="$1" old="$2"
    [ -e "$new" ] || return 1               # already gone
    [ -e "$old" ] && return 2               # something is back at the origin вЂ” skip
    mkdir -p "$(dirname "$old")"
    mv -n "$new" "$old" 2>/dev/null && return 0 || return 1
}
# drop history lines whose 'new' path appears (one per line) in file $1
_undo_purge() {
    [ -r "$HISTORY_FILE" ] || return 0
    local s o n
    : > "$HISTORY_FILE.tmp"
    while IFS=$'\t' read -r s o n; do
        grep -qxF -- "$n" "$1" 2>/dev/null && continue
        printf '%s\t%s\t%s\n' "$s" "$o" "$n" >> "$HISTORY_FILE.tmp"
    done < "$HISTORY_FILE"
    mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"
}
_undo_runs() {
    [ -r "$HISTORY_FILE" ] || { echo 0; return; }
    cut -f1 "$HISTORY_FILE" 2>/dev/null | sort -u | sed '/^$/d' | wc -l | tr -d ' '
}

# `dsort undo`: revert the most recent run; repeat to keep stepping back.
run_undo() {
    _undo_load        # _undo_prepare (inside) migrates legacy state + backfills past sorts from the log
    [ "${#U_NEW[@]}" -gt 0 ] || { echo "Nothing to undo."; return; }
    local latest="${U_STAMP[0]}" n=0 skip=0 i purge; purge=$(mktemp)
    for i in "${!U_NEW[@]}"; do
        [ "${U_STAMP[$i]}" = "$latest" ] || continue
        if _undo_one "${U_NEW[$i]}" "${U_OLD[$i]}"; then n=$((n+1)); else skip=$((skip+1)); fi
        printf '%s\n' "${U_NEW[$i]}" >> "$purge"
    done
    _undo_purge "$purge"; rm -f "$purge"
    local left; left=$(_undo_runs)
    echo "Reverted $n file(s) from the most recent run$([ "$skip" -gt 0 ] && echo " ($skip skipped)")."
    [ "${left:-0}" -gt 0 ] && echo "в†©  Run 'dsort undo' again to revert the previous run вЂ” $left earlier run(s) left."
}

# dry-run preview and stats reuse the sorter's own classify()/MANAGED_DIRS by
# sourcing it inside a subshell (its run-guard means sourcing has no side effects)
# shellcheck source=/dev/null  # $SORTER is resolved at runtime
run_preview() ( source "$SORTER" >/dev/null 2>&1 && preview )
run_stats() (
    # shellcheck source=/dev/null
    source "$SORTER" >/dev/null 2>&1 || { echo "Could not load sorter."; exit 1; }
    local d n sz arch
    printf '  %sFiles by category%s\n' "$BLD" "$R"
    for d in "${MANAGED_DIRS[@]}"; do
        [ -d "$DIR/$d" ] || continue
        n=$(find "$DIR/$d" -type f ! -name '.*' 2>/dev/null | wc -l | tr -d ' ')
        [ "${n:-0}" -eq 0 ] && continue
        sz=$(du -sh "$DIR/$d" 2>/dev/null | cut -f1)
        printf '   %-24s %5s files  %7s\n' "$d" "$n" "$sz"
    done
    if [ -d "$DIR/Archive" ]; then
        arch=$(find "$DIR/Archive" -type f ! -name '.*' 2>/dev/null | wc -l | tr -d ' ')
        sz=$(du -sh "$DIR/Archive" 2>/dev/null | cut -f1)
        printf '   %s%-24s %5s files  %7s%s\n' "$DIM" "Archive (all)" "$arch" "$sz" "$R"
    fi
    local last
    last=$(grep -hE ' (moved|archived|renamed): ' "$LOG" 2>/dev/null | tail -n1 | cut -c1-19)
    printf '\n   Last activity: %s\n' "${last:-(none yet)}"
)
# list the user's custom rules exactly as the sorter parses them
run_rules() (
    rf="$HOME/.downloads-rules.conf"
    if [ ! -r "$rf" ]; then
        echo "No custom rules yet. Create $rf with lines like:"
        echo "    *statement*           -> Documents/Finance"
        echo "    *.dwg                 -> 3D & CAD"
        echo "    source:*github.com*   -> Installers & Apps   (match the download's origin)"
        echo "(arrow may be -> or в†’; rules are checked before the built-in categories)"
        exit 0
    fi
    # shellcheck source=/dev/null
    source "$SORTER" >/dev/null 2>&1
    if [ "${#RULE_PAT[@]}" -eq 0 ]; then echo "Rules file present but no valid rules parsed."; exit 0; fi
    echo "Custom rules (checked before built-ins):"
    for i in "${!RULE_PAT[@]}"; do
        if [ "${RULE_KIND[$i]:-name}" = source ]; then printf '   %-28s в†’ %s   %s(download source)%s\n' "${RULE_PAT[$i]}" "${RULE_DEST[$i]}" "$DIM" "$R"
        else printf '   %-28s в†’ %s\n' "${RULE_PAT[$i]}" "${RULE_DEST[$i]}"; fi
    done
)

# `dsort find <text>`: where did a download go? Case-insensitive substring search
# across ~/Downloads (every sorted folder + Archive). Shows each hit's folder,
# flags anything still loose at the top, and prints a ready-to-run reveal command.
run_find() {
    local q="$*" dir="$HOME/Downloads" count=0 line rel base sub first=""
    [ -n "$q" ] || { echo "Usage: dsort find <part of a filename>"; return 1; }
    [ -d "$dir" ] || { echo "No ~/Downloads folder found."; return 1; }
    printf '  %sWhere did it go?%s  matches for "%s"\n\n' "$BLD" "$R" "$q"
    while IFS= read -r line; do
        rel="${line#"$dir"/}"; base="${rel##*/}"; sub="${rel%/*}"
        if [ "$sub" = "$rel" ]; then
            printf '   %s\n        %sВ· still loose at the top of Downloads (not sorted yet)%s\n' "$base" "$DIM" "$R"
        else
            printf '   %s\n        %sin%s  %s/\n' "$base" "$DIM" "$R" "$sub"
        fi
        [ -z "$first" ] && first="$line"
        count=$((count+1))
    done < <(find "$dir" -type f ! -path '*/.*' -iname "*$q*" 2>/dev/null | sort)
    if [ "$count" -eq 0 ]; then
        printf '   %sNothing matching "%s" under ~/Downloads.%s\n' "$DIM" "$q" "$R"; return 0
    fi
    if [ "$count" -eq 1 ]; then
        printf '\n  %sReveal it in Finder:%s  open -R "%s"\n' "$DIM" "$R" "$first"
    else
        printf '\n  %s%d matches. Reveal one in Finder with:%s  open -R "<path above>"\n' "$DIM" "$count" "$R"
    fi
}

# live "Folder categories" view: two columns (category | what routes there),
# wrapped to the terminal width, plus your custom rules. Reads the real table.
render_categories() (
    # shellcheck source=/dev/null
    source "$SORTER" >/dev/null 2>&1
    local W left cat exts wrapped ln first i
    W=$(tput cols 2>/dev/null); case "$W" in ''|*[!0-9]*) W=80 ;; esac; [ "$W" -lt 56 ] && W=80
    left=22; rightw=$(( W - left - 6 )); [ "$rightw" -lt 24 ] && rightw=24
    printf '\n  %sFolder categories%s   %sвЂ” where each kind of file is filed%s\n\n' "$BLD" "$R" "$DIM" "$R"
    category_map | while IFS='|' read -r cat exts; do
        wrapped=$(printf '%s' "$exts" | fold -s -w "$rightw")
        first=1
        while IFS= read -r ln; do
            if [ "$first" = 1 ]; then printf '  %s%-*s%s %s\n' "$BLD" "$left" "$cat" "$R" "$ln"; first=0
            else printf '  %-*s %s\n' "$left" "" "$ln"; fi
        done < <(printf '%s\n' "$wrapped")
    done
    if [ "${#RULE_PAT[@]}" -gt 0 ]; then
        printf '\n  %sYour custom rules%s   %s(checked first вЂ” override the above)%s\n\n' "$BLD" "$R" "$DIM" "$R"
        for i in "${!RULE_PAT[@]}"; do
            if [ "${RULE_KIND[$i]:-name}" = source ]; then printf '  %ssource:%-*s%s в†’  %s\n' "$GRN" "$((left-7))" "${RULE_PAT[$i]}" "$R" "${RULE_DEST[$i]}"
            else printf '  %s%-*s%s в†’  %s\n' "$GRN" "$left" "${RULE_PAT[$i]}" "$R" "${RULE_DEST[$i]}"; fi
        done
    else
        printf '\n  %sNo custom rules yet вЂ” add some in Settings в†’ Custom sorting rules.%s\n' "$DIM" "$R"
    fi
    echo
)

# Scrollable, read-only Folder-categories view. Built in-TUI (no `less`) so the
# exit and the on-screen hint match the rest of the menu and there's no
# alternate-screen nesting. Scrolls when the list is taller than the window.
do_categories() {
    local lines=() ln top=0 i H rows maxtop frame foot key
    while IFS= read -r ln; do lines+=("$ln"); done < <(render_categories)
    printf '\033[?25l'
    while :; do
        H=$(tput lines 2>/dev/null); case "$H" in ''|*[!0-9]*) H=24 ;; esac
        rows=$(( H - 2 )); [ "$rows" -lt 5 ] && rows=5
        maxtop=$(( ${#lines[@]} - rows )); [ "$maxtop" -lt 0 ] && maxtop=0
        [ "$top" -gt "$maxtop" ] && top="$maxtop"
        frame=""
        for (( i=top; i<top+rows && i<${#lines[@]}; i++ )); do frame="$frame${lines[$i]}"$'\n'; done
        if [ "${#lines[@]}" -gt "$rows" ]; then foot="${DIM}в†‘/в†“ scroll В· q or esc to go back${R}"
        else foot="${DIM}press q or esc to go back${R}"; fi
        _paint "$frame"$'\n'"  $foot"
        key=$(read_key)
        case "$key" in
            up|k)      [ "$top" -gt 0 ] && top=$((top-1)) ;;
            down|j)    [ "$top" -lt "$maxtop" ] && top=$((top+1)) ;;
            q|esc|"")  break ;;
        esac
    done
    printf '\033[?25l'; MSG=""
}

