# compact, colour-matched "recent activity" for the main menu вЂ” the same line
# style as the full Activity log (dim time В· name в†’ green dest), newest first,
# limited to the configured count (Settings в†’ Recent activity; 0 hides it).
recent_lines() {
    local n; n=$(get_recent_count)
    [ "${n:-0}" -gt 0 ] || return 0
    [ -s "$LOG" ] || return 0
    grep -E ' (moved|archived|duplicate): ' "$LOG" 2>/dev/null | tail -n "$n" | tail -r | awk \
        -v dim="$DIM" -v grn="$GRN" -v r="$R" '
    {
        t = substr($0, 12, 5)
        rest = substr($0, 21)                       # "verb: payload"
        ci = index(rest, ": "); verb = substr(rest, 1, ci-1); payload = substr(rest, ci+2)
        m = split(payload, p, " -> ")
        dest = p[m]; sub(/\/$/, "", dest)
        name = p[1]; for (i = 2; i < m; i++) name = name " -> " p[i]
        if (length(name) > 34) name = substr(name, 1, 33) "вЂ¦"
        tag = (verb == "archived") ? "  " dim "(archived)" r : (verb == "duplicate") ? "  " dim "(dup)" r : ""
        printf "   %s%s%s  %-34s %sв†’ %s%s%s\n", dim, t, r, name, grn, dest, r, tag
    }'
}

