# do_filter <exclude|only> — interactive multi-select: tick categories and/or add
# file extensions, saved to the matching list file. Arrows move, Enter toggles/acts.
do_filter() {
    local kind="$1" file title verb sel="" exts="" line c
    if [ "$kind" = only ]; then file="$ONLY_FILE"; title="Only sort these"; verb="sort only";
    else file="$EXCLUDE_FILE"; title="Exclude from sorting"; verb="exclude"; fi
    if [ -r "$file" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            case "$line" in ''|'#'*) continue ;; esac
            local known=0; for c in "${FILTER_CATS[@]}"; do [ "$c" = "$line" ] && { known=1; break; }; done
            if [ "$known" = 1 ]; then sel="$sel$line"$'\n'; else exts="$exts $line"; fi
        done < "$file"
    fi
    exts="${exts# }"
    local n=${#FILTER_CATS[@]} nrows focus=0 key i mark input; nrows=$((n+3))
    printf '\033[?25l'
    while :; do
        printf '\033[H\033[2J'
        printf '\n  %s%s%s  %s\n' "$BLD" "$title" "$R" "${DIM}— tick categories and/or add file types to $verb${R}"
        printf '  %s\n' "${DIM}─────────────────────────────────────────────${R}"
        for i in "${!FILTER_CATS[@]}"; do
            case $'\n'"$sel" in *$'\n'"${FILTER_CATS[$i]}"$'\n'*) mark="[${GRN}✓${R}]" ;; *) mark="[ ]" ;; esac
            if [ "$i" -eq "$focus" ]; then printf '   %s ▸ %s %s%s\n' "$REV" "$mark" "${FILTER_CATS[$i]}" "$R"
            else printf '      %s %s\n' "$mark" "${FILTER_CATS[$i]}"; fi
        done
        printf '  %s\n' "${DIM}─────────────────────────────────────────────${R}"
        if [ "$focus" -eq "$n" ]; then       printf '   %s ▸ File types: %s%s\n' "$REV" "${exts:-(none) — Enter to add}" "$R"
        else                                 printf '      File types: %s\n' "${exts:-(none) — Enter to add}"; fi
        if [ "$focus" -eq $((n+1)) ]; then   printf '   %s ▸ Clear all%s\n' "$REV" "$R"; else printf '      Clear all\n'; fi
        if [ "$focus" -eq $((n+2)) ]; then   printf '   %s ▸ Save & back%s\n' "$REV" "$R"; else printf '      Save & back\n'; fi
        printf '\n  %s↑/↓ move · enter toggle/choose · esc save & back%s\n' "$DIM" "$R"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + nrows - 1) % nrows )) ;;
            down|j) focus=$(( (focus + 1) % nrows )) ;;
            esc)    break ;;
            "")
                if [ "$focus" -lt "$n" ]; then
                    c="${FILTER_CATS[$focus]}"
                    case $'\n'"$sel" in
                        *$'\n'"$c"$'\n'*) sel=$(printf '%s' "$sel" | grep -vxF -- "$c"); [ -n "$sel" ] && sel="$sel"$'\n' ;;
                        *) sel="$sel$c"$'\n' ;;
                    esac
                elif [ "$focus" -eq "$n" ]; then
                    printf '\033[?25h'
                    printf '\n  Current file types: %s\n' "${exts:-(none)}"
                    printf '  Enter extensions to %s (space-separated, no dots; blank keeps current): ' "$verb"
                    IFS= read -r input; printf '\033[?25l'
                    [ -n "$input" ] && exts=$(printf '%s' "$input" | tr 'A-Z' 'a-z' | tr -s ' ')
                elif [ "$focus" -eq $((n+1)) ]; then sel=""; exts=""
                else break; fi ;;
        esac
    done
    : > "$file"
    { printf '%s' "$sel" | sed '/^$/d'; for c in $exts; do printf '%s\n' "$c"; done; } >> "$file"
    printf '\033[?25l'
    MSG="$title: $(filter_count "$kind") item(s) saved"
}

# remove the Nth custom rule (counting only valid rule lines) from the conf
_rules_delete() {
    local rf="$1" idx="$2" i=0 line norm
    : > "$rf.tmp"
    while IFS= read -r line || [ -n "$line" ]; do
        norm="${line//→/->}"
        case "$line" in ''|'#'*) printf '%s\n' "$line" >> "$rf.tmp"; continue ;; esac
        case "$norm" in *'->'*) ;; *) printf '%s\n' "$line" >> "$rf.tmp"; continue ;; esac
        if [ "$i" -eq "$idx" ]; then i=$((i+1)); continue; fi
        i=$((i+1)); printf '%s\n' "$line" >> "$rf.tmp"
    done < "$rf"
    mv "$rf.tmp" "$rf"
}

# add a rule: prompt for a pattern, then pick the destination folder
_rules_add() {
    local rf="$1" pat dest cats focus=0 n i key
    printf '\033[?25h'
    printf '\n  %sNew rule%s\n' "$BLD" "$R"
    printf '  Filename pattern (e.g. *statement*  or  *.dwg): '
    IFS= read -r pat; printf '\033[?25l'
    pat=$(printf '%s' "$pat" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ -z "$pat" ] && return
    cats=( "${FILTER_CATS[@]}" "Documents/PDFs" "Documents/Word & Text" "Media/Images" "Media/Video" "Type a custom folder…" )
    n=${#cats[@]}
    while :; do
        printf '\033[H\033[2J'
        printf '\n  %sSend "%s" to which folder?%s\n' "$BLD" "$pat" "$R"
        printf '  %s\n' "${DIM}──────────────────────────────────────────────${R}"
        for i in "${!cats[@]}"; do
            if [ "$i" -eq "$focus" ]; then printf '  %s ▸ %-40s%s\n' "$REV" "${cats[$i]}" "$R"
            else printf '     %s\n' "${cats[$i]}"; fi
        done
        printf '\n  %s↑/↓ move · enter choose · esc cancel%s\n' "$DIM" "$R"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + n - 1) % n )) ;;
            down|j) focus=$(( (focus + 1) % n )) ;;
            esc|q)  return ;;
            "")     dest="${cats[$focus]}"
                    if [ "$dest" = "Type a custom folder…" ]; then
                        printf '\033[?25h'; printf '\n  Folder (e.g. Documents/Finance): '; IFS= read -r dest; printf '\033[?25l'
                        dest=$(printf '%s' "$dest" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                    fi
                    [ -n "$dest" ] && printf '%s -> %s\n' "$pat" "$dest" >> "$rf"
                    return ;;
        esac
    done
}

# interactive custom-rules editor (no config-file editing needed)
do_rules() {
    local rf="$HOME/.downloads-rules.conf" pats dests line p d focus=0 key i n nrows
    printf '\033[?25l'
    while :; do
        pats=(); dests=()
        if [ -r "$rf" ]; then
            while IFS= read -r line || [ -n "$line" ]; do
                case "$line" in ''|'#'*) continue ;; esac
                line="${line//→/->}"; case "$line" in *'->'*) ;; *) continue ;; esac
                p=$(printf '%s' "${line%%->*}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                d=$(printf '%s' "${line#*->}"  | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                [ -n "$p" ] && [ -n "$d" ] && { pats+=("$p"); dests+=("$d"); }
            done < "$rf"
        fi
        n=${#pats[@]}; nrows=$((n+2)); [ "$focus" -ge "$nrows" ] && focus=$((nrows-1))
        printf '\033[H\033[2J'
        printf '\n  %sCustom sorting rules%s  %s— a pattern → a folder you choose%s\n' "$BLD" "$R" "$DIM" "$R"
        printf '  %s\n' "${DIM}──────────────────────────────────────────────${R}"
        [ "$n" -eq 0 ] && printf '     %s(none yet — add one below)%s\n' "$DIM" "$R"
        for i in "${!pats[@]}"; do
            if [ "$i" -eq "$focus" ]; then printf '  %s ▸ %-22s → %-20s%s  enter = delete\n' "$REV" "${pats[$i]}" "${dests[$i]}" "$R"
            else printf '     %-22s → %s\n' "${pats[$i]}" "${dests[$i]}"; fi
        done
        printf '  %s\n' "${DIM}──────────────────────────────────────────────${R}"
        if [ "$focus" -eq "$n" ]; then printf '  %s ▸ + Add a rule%s\n' "$REV" "$R"; else printf '     + Add a rule\n'; fi
        if [ "$focus" -eq $((n+1)) ]; then printf '  %s ▸ ← Back%s\n' "$REV" "$R"; else printf '     ← Back\n'; fi
        printf '\n  %s↑/↓ move · enter delete/add · esc back%s\n' "$DIM" "$R"
        key=$(read_key)
        case "$key" in
            up|k)   focus=$(( (focus + nrows - 1) % nrows )) ;;
            down|j) focus=$(( (focus + 1) % nrows )) ;;
            esc|q)  break ;;
            "")     if   [ "$focus" -lt "$n" ]; then _rules_delete "$rf" "$focus"; focus=0
                    elif [ "$focus" -eq "$n" ]; then _rules_add "$rf"; focus=0
                    else break; fi ;;
        esac
    done
    printf '\033[?25l'; MSG="Custom sorting rules updated"
}

activate() {
    if [ "$SCREEN" = settings ]; then
        case "$focus" in
            0)  toggle_notify ;;
            1)  toggle_cleannames ;;
            2)  pick_interval ;;
            3)  prompt_grace ;;
            4)  prompt_archivedays ;;
            5)  toggle_aging ;;
            6)  toggle_duplicates ;;
            7)  pick_largefile ;;
            8)  toggle_screenshotdate ;;
            9)  toggle_metanames ;;
            10) toggle_autounzip ;;
            11) toggle_autoupdate ;;
            12) do_categories ;;
            13) do_filter exclude ;;
            14) do_filter only ;;
            15) do_rules ;;
            16) SCREEN=main; focus=6 ;;
        esac
    else
        case "$focus" in
            0) toggle_sorter ;;
            1) do_run ;;
            2) do_preview ;;
            3) do_undo ;;
            4) do_stats ;;
            5) do_log ;;
            6) SCREEN=settings; focus=0 ;;
            7) do_update ;;
            8) do_help ;;
            9) QUIT=1 ;;
        esac
    fi
}

ui_main() {
    local QUIT=0 focus=0 MSG="" key SCREEN=main NROWS idx
    maybe_autoupdate      # only if Auto-update is ON; checks at most once a day
    # alternate screen: menu doesn't eat scrollback; prior content restored on exit
    [ -t 1 ] && printf '\033[?1049h'
    printf '\033[?25l'
    trap 'printf "\033[?1049l\033[?25h\033[0m"' EXIT
    while [ "$QUIT" -eq 0 ]; do
        [ "$SCREEN" = settings ] && NROWS=17 || NROWS=10
        draw
        MSG=""
        key=$(read_key) || break
        case "$key" in
            up|k)   focus=$(( (focus + NROWS - 1) % NROWS )); continue ;;
            down|j) focus=$(( (focus + 1) % NROWS )); continue ;;
            "")     activate; continue ;;
            [0-9])  # number shortcut: 1-9 -> rows 0-8, 0 -> row 9; jump + activate
                    if [ "$key" = 0 ]; then idx=9; else idx=$((key - 1)); fi
                    if [ "$idx" -lt "$NROWS" ]; then focus=$idx; activate; fi
                    continue ;;
        esac
        # only navigation keys are screen-specific now
        if [ "$SCREEN" = settings ]; then
            case "$key" in esc) SCREEN=main; focus=6 ;; q) QUIT=1 ;; esac
        else
            case "$key" in q|esc) QUIT=1 ;; esac
        fi
    done
    printf '\033[?1049l\033[?25h'
    show_status
}

# ---------- dispatch ----------

case "$1" in
    on)
        sorter_on
        echo "Downloads sorter: ON" ;;
    off)
        sorter_off
        echo "Downloads sorter: OFF (stays off until you run: dsort on)" ;;
    run)
        launchctl kickstart "$TARGET" && echo "Sort pass triggered." ;;
    log)
        tail -n "${2:-15}" "$LOG" ;;
    notify)
        case "$2" in
            on)  rm -f "$NONOTIFY_FLAG"; echo "Notifications: ON" ;;
            off) touch "$NONOTIFY_FLAG"; echo "Notifications: OFF" ;;
            *)   notify_is_on && echo "Notifications: ON" || echo "Notifications: OFF" ;;
        esac ;;
    cleannames)
        case "$2" in
            on)  touch "$CLEANFLAG"; echo "Filename cleanup: ON" ;;
            off) rm -f "$CLEANFLAG"; echo "Filename cleanup: OFF" ;;
            *)   clean_is_on && echo "Filename cleanup: ON" || echo "Filename cleanup: OFF" ;;
        esac ;;
    aging)
        case "$2" in
            on)  rm -f "$AGING_FLAG"; echo "Aging nudge: ON" ;;
            off) touch "$AGING_FLAG"; echo "Aging nudge: OFF" ;;
            *)   aging_is_on && echo "Aging nudge: ON" || echo "Aging nudge: OFF" ;;
        esac ;;
    duplicates)
        case "$2" in
            on)  rm -f "$DEDUP_FLAG"; echo "Duplicate routing: ON" ;;
            off) touch "$DEDUP_FLAG"; echo "Duplicate routing: OFF" ;;
            *)   dedup_is_on && echo "Duplicate routing: ON" || echo "Duplicate routing: OFF" ;;
        esac ;;
    largefiles)
        if [ -n "$2" ]; then
            case "$2" in
                r|recommended) set_largefile "$RECOMMENDED_LARGEFILE_GB" && echo "Big-file quarantine: ≥ $RECOMMENDED_LARGEFILE_GB GB (recommended)" ;;
                *) if set_largefile "$2"; then [ "$2" = 0 ] && echo "Big-file quarantine: OFF" || echo "Big-file quarantine: ≥ $2 GB → Large Files/"; else echo "Invalid (whole-number GB, 0 = off)." >&2; exit 1; fi ;;
            esac
        else
            lf=$(get_largefile); [ "$lf" = 0 ] && echo "Big-file quarantine: OFF (recommended $RECOMMENDED_LARGEFILE_GB GB)" || echo "Big-file quarantine: ≥ $lf GB (recommended $RECOMMENDED_LARGEFILE_GB GB)"
        fi ;;
    screenshotdate)
        case "$2" in
            on)  rm -f "$SS_FLAG"; echo "Screenshot dating: ON" ;;
            off) touch "$SS_FLAG"; echo "Screenshot dating: OFF" ;;
            *)   ss_is_on && echo "Screenshot dating: ON" || echo "Screenshot dating: OFF" ;;
        esac ;;
    metanames)
        case "$2" in
            on)  touch "$META_FLAG"; echo "Metadata naming: ON" ;;
            off) rm -f "$META_FLAG"; echo "Metadata naming: OFF" ;;
            *)   meta_is_on && echo "Metadata naming: ON" || echo "Metadata naming: OFF" ;;
        esac ;;
    autounzip)
        case "$2" in
            on)  touch "$AUTOUNZIP_FLAG"; echo "Auto-unzip: ON" ;;
            off) rm -f "$AUTOUNZIP_FLAG"; echo "Auto-unzip: OFF" ;;
            *)   unzip_is_on && echo "Auto-unzip: ON" || echo "Auto-unzip: OFF" ;;
        esac ;;
    autoupdate)
        case "$2" in
            on)  touch "$AUTOUPDATE_FLAG"; echo "Auto-update: ON" ;;
            off) rm -f "$AUTOUPDATE_FLAG"; echo "Auto-update: OFF" ;;
            *)   autoupdate_on && echo "Auto-update: ON" || echo "Auto-update: OFF" ;;
        esac ;;
    interval)
        if [ -n "$2" ]; then
            case "$2" in
                r|recommended) set_interval "$RECOMMENDED_INTERVAL" && echo "Auto-run interval: every $(fmt_interval "$RECOMMENDED_INTERVAL") (recommended)" ;;
                *) if set_interval "$2"; then echo "Auto-run interval: every $(fmt_interval "$2")"; else echo "Invalid (digits only, minimum 60s)." >&2; exit 1; fi ;;
            esac
        else
            iv=$(get_interval)
            echo "Auto-run interval: every $(fmt_interval "$iv") (${iv:-unset}s)"
            echo "Recommended:       every $(fmt_interval "$RECOMMENDED_INTERVAL") (${RECOMMENDED_INTERVAL}s)"
        fi ;;
    archivedays)
        if [ -n "$2" ]; then
            case "$2" in
                r|recommended) set_archivedays "$RECOMMENDED_ARCHIVE_DAYS" && echo "Archive age: $RECOMMENDED_ARCHIVE_DAYS days (recommended)" ;;
                *) if set_archivedays "$2"; then echo "Archive age: $2 days"; else echo "Invalid (whole number ≥ 1)." >&2; exit 1; fi ;;
            esac
        else
            echo "Archive age: $(get_archivedays) days (recommended $RECOMMENDED_ARCHIVE_DAYS)"
        fi ;;
    graceperiod|grace)
        if [ -n "$2" ]; then
            case "$2" in
                r|recommended) set_grace "$RECOMMENDED_GRACE" && echo "Grace period: $(fmt_grace "$RECOMMENDED_GRACE")" ;;
                *) if set_grace "$2"; then echo "Grace period: $(fmt_grace "$2") before a download is sorted"; else echo "Invalid (whole seconds, 0–86400; 0 = immediate)." >&2; exit 1; fi ;;
            esac
        else
            echo "Grace period: $(fmt_grace "$(get_grace)") (recommended ${RECOMMENDED_GRACE}s)"
        fi ;;
    preview)
        run_preview ;;
    undo)
        run_undo ;;
    stats)
        run_stats ;;
    rules)
        run_rules ;;
    find)
        shift; run_find "$@" ;;
    exclude|only)
        kind="$1"; [ "$kind" = only ] && ff="$ONLY_FILE" || ff="$EXCLUDE_FILE"
        case "${2:-}" in
            clear) : > "$ff"; echo "$kind list cleared" ;;
            "")    if [ -s "$ff" ] && grep -qvE '^[[:space:]]*(#|$)' "$ff"; then
                       echo "$kind list (categories or extensions):"; grep -vE '^[[:space:]]*(#|$)' "$ff" | sed 's/^/  /'
                   else echo "$kind list is empty — set it from: dsort → Settings"; fi ;;
            *)     shift; for a in "$@"; do printf '%s\n' "$a" >> "$ff"; done
                   echo "added to $kind list: $*" ;;
        esac ;;
    version|--version|-v)
        echo "Downloads Sorter v$VERSION" ;;
    update)
        run_update ;;
    status)
        show_status ;;
    ui)
        ui_main ;;
    "")
        # bare invocation: interactive UI on a terminal, plain status otherwise
        if [ -t 0 ] && [ -t 1 ]; then ui_main; else show_status; fi ;;
    *)
        cat >&2 <<'USAGE'
Usage: dsort <command>   (bare = interactive UI)
  on | off            enable/disable the sorter
  status              text status of every setting
  run                 trigger a sort pass now
  preview             dry run — show where loose files would go (no moves)
  undo                move the last run's files back
  stats               file counts / sizes per category
  rules               list custom ~/.downloads-rules.conf rules
  exclude [.. |clear]  categories/extensions to never sort (bare = list)
  only [.. |clear]     sort ONLY these categories/extensions (bare = list)
  log [n]             last n log lines (default 15)
  notify on|off       "Downloads sorted" notifications
  cleannames on|off   opt-in filename cleanup
  aging on|off        weekly nudge for Archive files over a year old
  duplicates on|off   route byte-identical files to Duplicates/
  largefiles [n|r]    GB threshold for Large Files/ (0 = off, r = recommended)
  screenshotdate on|off  date-prefix screenshots + bucket by month
  metanames on|off    opt-in: rename PDFs from their embedded title
  autounzip on|off    opt-in: expand .zip into a same-named subfolder
  interval [secs|r]   show/set safety-net auto-run cadence (r = recommended)
  archivedays [n|r]   show/set Archive age in days (r = recommended)
  version             print the installed version
  update              download + install the latest version from GitHub
USAGE
        exit 1 ;;
esac
